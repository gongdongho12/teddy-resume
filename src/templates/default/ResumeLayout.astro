---
import type { Lang, ResumeProfile } from '@/lib/resume-types';
import { messages } from '@/lib/messages';
import { t, bullets } from '@/lib/localize';
import { getPortfolioProjectHref } from '@/lib/portfolio-links';
import TemplateSelector from '@/components/TemplateSelector.astro';
import AutoPagination from '@/components/AutoPagination.astro';
import CommonHead from '@/components/CommonHead.astro';
import PortfolioProjectTitleLink from '@/components/PortfolioProjectTitleLink.astro';
import ResumeTopBar from '@/components/ResumeTopBar.astro';

interface Props {
  lang: Lang;
  profile: ResumeProfile;
}

const { lang, profile } = Astro.props;
const m = messages(lang);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <CommonHead lang={lang} />
    <style>
      @page {
        size: A4;
        margin: 0;
      }
      @media print {
        /* Hide everything except the article */
        body > *:not(article) {
          display: none !important;
        }
        article {
          position: relative;
          margin: 0 !important;
          padding: 0 !important;
          width: 210mm !important;
          display: block !important;
        }
        body {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
          background-color: white;
        }
        h2.print\:break-before-page {
          break-before: page !important;
        }
      }
    </style>
  </head>
  <body class="min-h-screen bg-gray-100 print:bg-white text-sm leading-relaxed text-black antialiased">
    <TemplateSelector lang={lang} currentTemplate="default" />
    <AutoPagination />

    <ResumeTopBar
      lang={lang}
      currentTemplate="default"
      maxWidthClass="max-w-[850px]"
      containerClass="pb-4 text-sm"
      printHintStyle="popover"
      printHintAccentClass="text-[#0f3460]"
      showPortfolioLink={true}
      portfolioLinkClass="font-semibold text-slate-700 hover:underline"
      languageLinkClass="text-blue-800 hover:text-blue-900 hover:underline"
      activeLanguageClass="text-[#0f3460]"
    />

    <!-- DOCUMENT RENDERER -->
    <article class="mx-auto flex flex-col gap-4 w-full max-w-[794px] xl:max-w-none xl:flex-row xl:flex-wrap xl:justify-center xl:px-20 print:block print:w-[210mm] mb-10 print:mb-0 transition-all duration-500">
      
      <!-- PAGE 1: HEADER, EXPERIENCE, SKILLS, AWARDS -->
      <div class="flex flex-col min-h-[297mm] print:h-[297mm] print:min-h-[297mm] print:max-h-[297mm] bg-white shadow-md print:shadow-none relative overflow-hidden w-full max-w-[794px] xl:max-w-[794px]">
        <!-- COMPACT HEADER -->
        <header class="bg-gradient-to-br from-[#1a1a2e] to-[#0f3460] text-white px-10 py-7 print:px-[15mm] print:py-[10mm] flex flex-col md:flex-row justify-between items-start gap-8">
          <!-- Left: Name and Summary -->
          <div class="flex-1">
            <div class="mb-3">
              {
                lang === 'en' ? (
                  <>
                    <h1 class="text-3xl font-black tracking-tight md:text-4xl mb-0.5">
                      {profile.name_en}
                    </h1>
                    <p class="text-blue-200 text-xs font-medium tracking-wide">{profile.name}</p>
                  </>
                ) : (
                  <h1 class="text-3xl font-black tracking-tight md:text-4xl">{profile.name}</h1>
                )
              }
            </div>
            <p class="whitespace-pre-line text-[13px] text-blue-50/90 leading-[1.6] max-w-2xl">
              {t(profile.summary, lang)}
            </p>
          </div>

          <!-- Right: Contact Info -->
          <address class="flex flex-col gap-1.5 text-[12px] font-medium not-italic text-blue-200 tracking-wide md:text-right shrink-0 pt-1">
            <span>{profile.contact.phone}</span>
            <a href={`mailto:${profile.contact.email}`} class="hover:text-white hover:underline transition-colors">{profile.contact.email}</a>
            <a href={profile.contact.github_url} target="_blank" rel="noreferrer" class="hover:text-white hover:underline transition-colors">{profile.contact.github_label}</a>
            <a href={profile.contact.linkedin_url} target="_blank" rel="noreferrer" class="hover:text-white hover:underline transition-colors">{profile.contact.linkedin_label}</a>
          </address>
        </header>

        <section class="px-10 py-7 md:px-12 md:py-6 print:px-[15mm] print:py-[10mm] flex-1">
          <div class="grid grid-cols-1 md:grid-cols-[1fr_15rem] gap-10 print:gap-8">
            
            <!-- EXPERIENCE -->
            <div class="space-y-6 print:space-y-5">
              <section>
                <h2
                  class="mb-6 border-b-2 border-[#0f3460] pb-2 text-[14px] font-bold uppercase tracking-[0.2em] text-[#0f3460]"
                >
                  {m.experience}
                </h2>
                <div class="space-y-5 print:space-y-4">
                  {
                    profile.experience.map((exp) => (
                      <div class="break-inside-avoid">
                        <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-1.5 gap-2">
                          <div class="flex flex-wrap items-baseline gap-x-2">
                            <h3 class="text-[16px] font-bold text-black">{t(exp.company, lang)}</h3>
                            {exp.role && (
                              <span class="text-[13.5px] font-bold text-gray-500 italic">
                                ({t(exp.role, lang)})
                              </span>
                            )}
                          </div>
                          <span class="whitespace-nowrap text-[12.5px] font-semibold text-[#0f3460] bg-blue-50 px-2 py-0.5 rounded">
                            {t(exp.period, lang)}
                          </span>
                        </div>
                        <p class="whitespace-pre-line text-[13.5px] leading-[1.6] text-gray-800">
                          {t(exp.description, lang)}
                        </p>
                      </div>
                    ))
                  }
                </div>
              </section>
            </div>

            <!-- SIDEBAR: SKILLS, EDUCATION, AWARDS, LANGUAGES -->
            <aside class="space-y-8 print:space-y-6">
              <!-- TECHNICAL SKILLS -->
              <section>
                <h2 class="mb-4 border-b-2 border-[#0f3460] pb-1.5 text-[12px] font-bold uppercase tracking-[0.2em] text-[#0f3460]">
                  Technical Skills
                </h2>
                <div class="space-y-4 print:space-y-3.5">
                  {/* Categorized Skills */}
                  <div class="space-y-0.5">
                    <p class="text-[10px] font-extrabold text-blue-800 uppercase tracking-wider">Programming Language</p>
                    <ul class="text-[12px] text-gray-800 font-medium leading-snug">
                      <li>- Java / Kotlin</li>
                      <li>- JavaScript / TypeScript</li>
                      <li>- Dart</li>
                    </ul>
                  </div>
                  <div class="space-y-0.5">
                    <p class="text-[10px] font-extrabold text-blue-800 uppercase tracking-wider">Framework / Library</p>
                    <ul class="text-[12px] text-gray-800 font-medium leading-snug">
                      <li>- Spring Boot / Spring Batch</li>
                      <li>- Express.js / Next.js / React.js</li>
                      <li>- Flutter</li>
                    </ul>
                  </div>
                  <div class="space-y-0.5">
                    <p class="text-[10px] font-extrabold text-blue-800 uppercase tracking-wider">DB / Infra</p>
                    <ul class="text-[12px] text-gray-800 font-medium leading-snug">
                      <li>- MySQL / Redis</li>
                      <li>- Docker / Kubernetes / ArgoCD</li>
                      <li>- GCP / Kafka / Jenkins</li>
                    </ul>
                  </div>
                  <div class="space-y-0.5">
                    <p class="text-[10px] font-extrabold text-blue-800 uppercase tracking-wider">Mobile / ETC</p>
                    <ul class="text-[12px] text-gray-800 font-medium leading-snug">
                      <li>- Android / iOS (Hybrid)</li>
                      <li>- GitHub Actions / Firebase</li>
                    </ul>
                  </div>
                </div>
              </section>

              <!-- EDUCATION -->
              <section>
                <h2 class="mb-4 border-b-2 border-[#0f3460] pb-1.5 text-[12px] font-bold uppercase tracking-[0.2em] text-[#0f3460]">
                  {m.education}
                </h2>
                <div class="space-y-4">
                  {
                    profile.education.map((ed) => (
                      <div class="break-inside-avoid flex flex-col">
                        <span class="text-[13px] font-bold text-black mb-0.5 leading-tight">{t(ed.school, lang)}</span>
                        <span class="text-[12px] font-medium text-gray-800 mb-0.5">{t(ed.degree, lang)}</span>
                        <span class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">{t(ed.period, lang)}</span>
                      </div>
                    ))
                  }
                </div>
              </section>

              <!-- AWARDS -->
              {profile.awards.length > 0 && (
                <section>
                  <h2 class="mb-4 border-b-2 border-[#0f3460] pb-1.5 text-[12px] font-bold uppercase tracking-[0.2em] text-[#0f3460]">
                    HONORS & AWARDS
                  </h2>
                  <div class="space-y-4">
                    {
                      profile.awards.map((award) => (
                        <div class="break-inside-avoid flex flex-col">
                          <span class="text-[13px] font-bold text-black mb-0.5 leading-tight">
                            {award.title}
                          </span>
                          {award.subtitle && (
                            <span class="text-[11px] text-gray-700 font-medium">
                              {t(award.subtitle, lang)}
                            </span>
                          )}
                        </div>
                      ))
                    }
                  </div>
                </section>
              )}

              <!-- LANGUAGES -->
              <section>
                <h2 class="mb-4 border-b-2 border-[#0f3460] pb-1.5 text-[12px] font-bold uppercase tracking-[0.2em] text-[#0f3460]">
                  Languages
                </h2>
                <div class="space-y-3">
                  <div class="flex flex-col">
                    <span class="text-[12.5px] font-bold text-black mb-0.5">Korean</span>
                    <span class="text-[11.5px] text-gray-700 font-medium leading-tight">네이티브, 테크 스피치 및 문서화 가능</span>
                  </div>
                  <div class="flex flex-col">
                    <span class="text-[12.5px] font-bold text-black mb-0.5">English</span>
                    <span class="text-[11.5px] text-gray-700 font-medium leading-tight">문서 검색 및 읽기, 기술 아티클 작성 가능</span>
                  </div>
                </div>
              </section>
            </aside>
          </div>
        </section>
      </div>

      <!-- PAGE 2+: PROJECTS & ACTIVITIES (AUTO-PAGINATED) -->
      <div class="auto-paginate min-h-[297mm] print:min-h-0 print:h-auto bg-white shadow-md print:shadow-none overflow-hidden w-full max-w-[794px] xl:max-w-[794px]">
        <section class="paginate-content px-10 py-0 print:px-[15mm] print:py-0">
          {
            profile.projectSections.map((section) => (
              <>
                <h2
                  class="mb-6 border-b-2 border-[#0f3460] pb-2 text-[14px] font-bold uppercase tracking-[0.2em] text-[#0f3460] mt-0 first:mt-0 print:mt-0 print:break-before-page"
                >
                  {t(section.heading, lang)}
                </h2>
                {section.projects.map((proj) => (
                  <div class="break-inside-avoid border border-gray-100 bg-white p-5 rounded shadow-sm print:shadow-none print:border-gray-200 mb-4 last:mb-0 print:mb-6 print:pb-8">
                    <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2 border-b border-gray-100 pb-2.5">
                      <h3 class="text-[16px] font-bold text-black flex items-center gap-2">
                        <PortfolioProjectTitleLink
                          href={getPortfolioProjectHref(lang, proj.portfolioSlug, proj.portfolioAnchor)}
                          label={t(proj.title, lang)}
                          className="text-black hover:text-[#0f3460] print:text-black print:no-underline"
                          externalHref={proj.externalUrl}
                          externalClassName="text-gray-500 hover:text-[#0f3460]"
                        />
                        {proj.badge && (
                          <span class="rounded bg-[#0f3460] px-2 py-0.5 text-[11px] font-bold tracking-widest text-white uppercase">
                            {t(proj.badge, lang)}
                          </span>
                        )}
                      </h3>
                      <span class="whitespace-nowrap text-[14px] font-bold text-gray-600 mt-2 md:mt-0">
                        {t(proj.period, lang)}
                      </span>
                    </div>
                    
                    {proj.summary && (
                      <p class="mb-4 whitespace-pre-line text-[14px] text-gray-800 leading-[1.6] font-medium bg-gray-50 px-4 py-3 rounded-sm border-l-4 border-gray-200">
                        {t(proj.summary, lang)}
                      </p>
                    )}

                    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6">
                      <!-- LEFT: HIGHLIGHTS -->
                      <div class="space-y-4">
                        <ul class="grid grid-cols-1 gap-y-1.5 list-disc pl-5 marker:text-[#0f3460]">
                          {bullets(proj.highlights, lang).map((line) => (
                            <li class="pl-1 text-[13.5px] text-gray-800 leading-[1.6]">{line}</li>
                          ))}
                        </ul>
                        
                        {proj.results && bullets(proj.results, lang).length > 0 && (
                          <div class="mt-3 pt-3 border-t border-dashed border-gray-100">
                            <p class="mb-2.5 text-[12px] font-bold uppercase tracking-wider text-[#0f3460]">{m.results}</p>
                            <ul class="grid grid-cols-1 gap-y-2.5 list-none pl-0">
                              {bullets(proj.results, lang).map((line) => (
                                <li class="relative pl-5 text-[14px] font-bold text-gray-900 leading-[1.6] before:absolute before:left-0 before:top-[8px] before:w-1.5 before:h-1.5 before:bg-[#0f3460] before:rotate-45">
                                  {line}
                                </li>
                              ))}
                            </ul>
                          </div>
                        )}
                      </div>

                      <!-- RIGHT: TECH STACK SIDEBAR -->
                      {proj.tech?.length > 0 && (
                        <aside class="flex flex-col">
                          <div class="h-full bg-slate-50/50 rounded-sm border-l-2 border-gray-100 p-2 md:p-3.5">
                            <div class="flex flex-row flex-wrap md:flex-col md:items-end gap-1.5 md:gap-1 md:text-right font-bold text-gray-600 text-[11.5px] font-sans tracking-tight">
                              {proj.tech.map((item) => (
                                <span class="break-words px-2 py-0.5 md:px-0 md:py-0 bg-gray-100 md:bg-transparent rounded-full md:rounded-none">
                                  {item}
                                </span>
                              ))}
                            </div>
                          </div>
                        </aside>
                      )}
                    </div>
                  </div>
                ))}
              </>
            ))
          }

          {/* ACTIVITIES SECTION */}
          <>
            <h2
              class="mb-6 border-b-2 border-[#0f3460] pb-2 text-[14px] font-bold uppercase tracking-[0.2em] text-[#0f3460] mt-0 print:mt-0 print:break-before-page"
            >
              {m.activities}
            </h2>
            {
              Array.from({ length: Math.ceil(profile.activities.length / 2) }).map((_, i) => (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-8 mb-8 last:mb-0">
                  {profile.activities.slice(i * 2, i * 2 + 2).map((a) => (
                    <div class="break-inside-avoid flex flex-col border-l-4 border-gray-100 pl-4 py-1">
                      <div class="flex flex-col mb-1.5">
                        <span class="text-[15px] font-bold text-black leading-snug">{t(a.title, lang)}</span>
                        <span class="text-[12px] text-gray-500 font-bold uppercase tracking-widest">{t(a.period, lang)}</span>
                      </div>
                      {a.description && (
                        <p class="text-[13.5px] text-gray-700 leading-relaxed whitespace-pre-line">
                          {t(a.description, lang)}
                        </p>
                      )}
                    </div>
                  ))}
                </div>
              ))
            }
          </>
        </section>
      </div>
    </article>
  </body>
</html>


