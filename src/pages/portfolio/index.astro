---
import CommonHead from '@/components/CommonHead.astro';
import { DEFAULT_LANG, getPortfolioUrl, LANGUAGE_LABELS, SUPPORTED_LANGS } from '@/lib/i18n';

const defaultPortfolioUrl = getPortfolioUrl(DEFAULT_LANG);
const portfolioLinks = SUPPORTED_LANGS.map((lang) => ({
  href: getPortfolioUrl(lang),
  label: lang === 'ko' ? `${LANGUAGE_LABELS[lang]} 포트폴리오` : `${LANGUAGE_LABELS[lang]} Portfolio`,
}));
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <CommonHead title="Portfolio" />
    <noscript>
      <meta http-equiv="refresh" content={`0;url=${defaultPortfolioUrl}`} />
    </noscript>
  </head>
  <body class="min-h-screen bg-gray-100 p-8 font-sans text-sm text-gray-600 print:bg-transparent">
    <script
      is:inline
      define:vars={{
        defaultPortfolioUrl,
        koPortfolioUrl: getPortfolioUrl('ko'),
        enPortfolioUrl: getPortfolioUrl('en'),
      }}
    >
      const fallbackLang = 'ko';
      const langTargets = {
        ko: koPortfolioUrl,
        en: enPortfolioUrl,
      };
      const supportedLangs = Object.keys(langTargets);
      const browserLanguages =
        Array.isArray(navigator.languages) && navigator.languages.length > 0
          ? navigator.languages
          : [navigator.language || fallbackLang];

      const detectedLang =
        browserLanguages
          .map((value) => String(value).toLowerCase().split('-')[0])
          .find((value) => supportedLangs.includes(value)) || fallbackLang;

      window.location.replace(langTargets[detectedLang] || defaultPortfolioUrl);
    </script>

    <p class="text-center">
      {portfolioLinks.map((link, index) => (
        <>
          {index > 0 && <span class="mx-2 text-gray-400">·</span>}
          <a class="font-medium text-indigo-800 underline" href={link.href}>{link.label}</a>
        </>
      ))}
    </p>
  </body>
</html>
