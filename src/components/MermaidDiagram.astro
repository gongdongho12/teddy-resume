---
interface Props {
  title: string;
  description: string;
  code: string;
  exampleTitle?: string;
  exampleSteps?: string[];
}

const { title, description, code, exampleTitle, exampleSteps = [] } = Astro.props;
---

<section class="space-y-4 rounded-[1.5rem] border border-slate-900/10 bg-white/55 p-4 sm:p-5">
  <div class="flex flex-wrap items-start justify-between gap-3 rounded-[1.2rem] border border-slate-900/10 bg-white/80 px-4 py-4">
    <div class="space-y-2">
      <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-sky-800">
        Mermaid View
      </p>
      <p class="text-lg font-semibold tracking-[-0.02em] text-slate-950">
        {title}
      </p>
      <p class="max-w-3xl text-sm leading-7 text-slate-600">
        {description}
      </p>
    </div>
  </div>

  <div class="portfolio-mermaid overflow-x-auto rounded-[1.4rem] border border-slate-900/10 bg-[linear-gradient(180deg,#ffffff_0%,#f6fbff_100%)] p-3 sm:p-4">
    <pre class="js-mermaid m-0 min-w-[18rem] bg-transparent text-sm">{code}</pre>
  </div>

  {exampleSteps.length > 0 && (
    <div class="rounded-[1.2rem] border border-slate-900/10 bg-[#f8fbfe] px-4 py-4">
      <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-emerald-700">
        {exampleTitle ?? 'Example'}
      </p>
      <ul class="mt-3 space-y-2">
        {exampleSteps.map((step) => (
          <li class="relative pl-4 text-sm leading-7 text-slate-700 before:absolute before:left-0 before:top-3 before:h-px before:w-2.5 before:bg-emerald-600">
            {step}
          </li>
        ))}
      </ul>
    </div>
  )}
</section>
