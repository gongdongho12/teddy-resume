---
import type { Lang } from '@/lib/resume-types';

interface Props {
  lang: Lang;
  accentClass?: string;
}

const {
  lang,
  accentClass = 'text-[#0f3460]',
} = Astro.props;
const label = lang === 'ko' ? '브라우저 인쇄 / 저장' : 'Print / Save';
const mobileLabel = lang === 'ko' ? '인쇄 / 저장' : 'Print / Save';
const panelTitle = lang === 'ko' ? '권장 인쇄 설정' : 'Recommended Print Settings';
const panelSubtitle =
  lang === 'ko'
    ? '마우스를 올리면 예시 이미지를 볼 수 있어요'
    : 'Hover to preview the recommended setup';
const panelBadge = lang === 'ko' ? '예시' : 'Preview';
const panelCaption =
  lang === 'ko'
    ? '브라우저 인쇄 창에서 배경 그래픽을 포함하고 여백을 없음으로 맞추면 현재 레이아웃을 가장 깔끔하게 저장하거나 출력할 수 있습니다.'
    : 'Turn on background graphics and set margins to none in the browser print dialog for the cleanest PDF or printed layout.';
const imageAlt =
  lang === 'ko'
    ? '여백 없음 옵션이 강조된 브라우저 인쇄 설정 예시'
    : 'Browser print settings preview with margins set to none';
---
<div class="group relative z-[100]">
  <button
    id="browser-print-btn"
    type="button"
    class="inline-flex items-center gap-1.5 whitespace-nowrap rounded-xl px-2 py-1.5 text-[12px] font-medium text-slate-700 transition-colors hover:bg-slate-100 hover:text-slate-900 focus:outline-none focus-visible:bg-slate-100 focus-visible:ring-2 focus-visible:ring-[#0f3460]/15 font-sans sm:gap-2 sm:px-3 sm:py-2 sm:text-[13px]"
    title={label}
    aria-describedby="browser-print-popover"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      class:list={['shrink-0', accentClass]}
    >
      <path d="M6 9V2h12v7" />
      <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
      <rect x="6" y="14" width="12" height="8" />
    </svg>
    <span class="sm:hidden">{mobileLabel}</span>
    <span class="hidden sm:inline">{label}</span>
  </button>

  <div
    id="browser-print-popover"
    class="pointer-events-none absolute right-0 top-full z-[120] mt-3 hidden w-[24rem] max-w-[calc(100vw-4rem)] translate-y-1 opacity-0 transition duration-200 ease-out sm:block sm:w-[26rem] group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:translate-y-0 group-focus-within:opacity-100"
  >
    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-2xl ring-1 ring-slate-900/5">
      <div class="flex items-start justify-between gap-3 border-b border-slate-100 bg-slate-50 px-4 py-3">
        <div>
          <p class:list={['text-[11px] font-semibold uppercase tracking-[0.18em]', accentClass]}>
            {panelTitle}
          </p>
          <p class="mt-1 text-xs text-slate-500">{panelSubtitle}</p>
        </div>
        <span class:list={['rounded-full bg-white px-2 py-1 text-[11px] font-semibold shadow-sm', accentClass]}>
          {panelBadge}
        </span>
      </div>

      <img
        src="/images/print-settings-preview.svg"
        alt={imageAlt}
        class="block w-full border-b border-slate-100 bg-slate-100"
        loading="lazy"
      />

      <p class="px-4 py-3 text-xs leading-relaxed text-slate-600">
        {panelCaption}
      </p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('browser-print-btn');
    if (!btn) return;

    btn.addEventListener('click', () => {
      if (typeof window.__resumeOpenPrintDialog === 'function') {
        window.__resumeOpenPrintDialog();
        return;
      }

      window.print();
    });
  });
</script>
