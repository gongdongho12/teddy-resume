---
import CommonHead from '@/components/CommonHead.astro';
import type { Lang, ResumeProfile } from '@/lib/resume-types';
import { messages } from '@/lib/messages';
import { t, bullets } from '@/lib/localize';
import { getPortfolioProjectHref } from '@/lib/portfolio-links';
import TemplateSelector from '@/components/TemplateSelector.astro';
import AutoPagination from '@/components/AutoPagination.astro';
import PortfolioProjectTitleLink from '@/components/PortfolioProjectTitleLink.astro';
import ResumeTopBar from '@/components/ResumeTopBar.astro';

interface Props {
  lang: Lang;
  profile: ResumeProfile;
}

const { lang, profile } = Astro.props;
const m = messages(lang);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <CommonHead lang={lang} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Pretendard:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      @page {
        size: A4;
        margin: 15mm; /* Professional resume margins */
      }
      @media print {
        body {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }
      }
    </style>
  </head>
  <body class="min-h-screen bg-gray-100 print:bg-white text-[14px] leading-snug text-gray-800 antialiased font-sans">
    <TemplateSelector lang={lang} currentTemplate="minimal" />
    <AutoPagination />

    <ResumeTopBar
      lang={lang}
      currentTemplate="minimal"
      maxWidthClass="max-w-[850px]"
      containerClass="pb-3 text-[13px]"
      printHintTextClass="text-gray-500"
      showCanvasPrintButton={true}
      languageLinkClass="text-black hover:text-gray-700 hover:underline"
      activeLanguageClass="text-black"
      contactToggleLabelClass="text-black"
      />

    <!-- DOCUMENT RENDERER -->
    <article class="mx-auto flex flex-col gap-4 w-full max-w-[850px] xl:max-w-none xl:flex-row xl:flex-wrap xl:justify-center xl:px-20 print:block print:w-[210mm] mb-10 print:mb-0 transition-all duration-500">
      
      <!-- HEADER SUMMARY -->
      <section class="flex flex-col justify-center px-12 md:px-16 pt-16 pb-12 print:pt-4 print:pb-8 border-b border-gray-100 bg-white shadow-sm print:shadow-none border border-gray-200 print:border-none w-full max-w-[850px] xl:max-w-[850px]">
        <header class="w-full">
          <div class="mb-8">
            {
              lang === 'en' ? (
                <>
                  <h1 class="text-5xl font-bold text-black tracking-tight mb-2">
                    {profile.name_en}
                  </h1>
                  <p class="text-lg text-gray-500 font-medium tracking-wide">{profile.name}</p>
                </>
              ) : (
                <h1 class="text-5xl font-bold text-black tracking-tight mb-2">
                  {profile.name}
                </h1>
              )
            }
          </div>
          
          <p class="whitespace-pre-line text-[15px] text-gray-600 leading-[1.7] max-w-2xl mb-8">
            {t(profile.summary, lang)}
          </p>

          <address data-contact-visibility class="flex flex-col gap-2 text-[14px] text-gray-500 font-medium not-italic border-l-2 border-black pl-5">
            <span class="text-black">{profile.contact.phone}</span>
            <a href={`mailto:${profile.contact.email}`} class="hover:text-black hover:underline">{profile.contact.email}</a>
            <a href={profile.contact.github_url} target="_blank" rel="noreferrer" class="hover:text-black hover:underline">{profile.contact.github_label}</a>
            <a href={profile.contact.linkedin_url} target="_blank" rel="noreferrer" class="hover:text-black hover:underline">{profile.contact.linkedin_label}</a>
          </address>

        </header>
      </section>

      <!-- MAIN CONTENT (AUTO-PAGINATED) -->
      <div class="auto-paginate bg-white shadow-sm print:shadow-none border border-gray-200 print:border-none w-full max-w-[850px] xl:max-w-[850px]">
        <section class="paginate-content px-12 md:px-16 pb-16 pt-12 print:px-8 print:py-8">
        
        <div class="space-y-16">
          
          <!-- EXPERIENCE -->
          <section>
            <h2 class="mb-6 text-[15px] font-bold text-black border-b-2 border-black pb-2 uppercase tracking-widest">
              {m.experience}
            </h2>
            <div class="space-y-10">
              {
                profile.experience.map((exp) => (
                  <div class="break-inside-avoid relative pl-8 before:absolute before:left-2 before:-top-0.5 before:bottom-0 before:w-px before:bg-gray-200">
                    <div class="absolute left-0 top-1.5 w-[17px] h-[17px] bg-white border-[4px] border-black rounded-full" />
                    <div class="flex flex-wrap items-baseline justify-between gap-2 mb-2">
                      <h3 class="text-[16px] font-bold text-black tracking-tight">
                        <PortfolioProjectTitleLink
                          label={t(exp.company, lang)}
                          className="text-black"
                        />
                      </h3>
                      <span class="whitespace-nowrap text-[13.5px] font-medium text-gray-500 bg-gray-50 px-2 py-0.5 rounded">
                        {t(exp.period, lang)}
                      </span>
                    </div>
                    <div class="flex flex-wrap items-baseline justify-between gap-2 mb-3">
                      <p class="text-[14px] font-bold text-gray-700">{exp.role ? t(exp.role, lang) : ''}</p>
                      {lang === 'en' && exp.location_en && (
                        <p class="text-[13.5px] text-gray-400">{exp.location_en}</p>
                      )}
                    </div>
                    {exp.descriptionLead?.[lang]?.trim() ? (
                      <>
                        <p class="mb-2 text-[14.5px] text-gray-600 leading-[1.7]">
                          {exp.descriptionLead[lang]}
                        </p>
                        <ul class="space-y-1.5 pl-5 text-[14.5px] text-gray-600 leading-[1.7] list-disc marker:text-gray-700">
                          {t(exp.description, lang).split('\n').map((line) => line.trim()).filter(Boolean).map((line) => (
                            <li>{line}</li>
                          ))}
                        </ul>
                      </>
                    ) : (
                      <p class="whitespace-pre-line text-[14.5px] text-gray-600 leading-[1.7]">
                        {t(exp.description, lang)}
                      </p>
                    )}
                  </div>
                ))
              }
            </div>
          </section>

          <!-- PROJECTS -->
          {
            profile.projectSections.map((section) => (
              <section>
                <h2 class="mb-6 text-[15px] font-bold text-black border-b-2 border-black pb-2 uppercase tracking-widest">
                  {t(section.heading, lang)}
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  {section.projects.map((proj) => (
                    <div class="break-inside-avoid print:mb-8 text-[14px]">
                      <div class="mb-2">
                         <div class="flex flex-wrap items-baseline justify-between mb-1.5">
                           <h3 class="text-[15.5px] font-bold text-black tracking-tight flex items-center gap-2">
                        <PortfolioProjectTitleLink
                          href={getPortfolioProjectHref(lang, proj.portfolioSlug, proj.portfolioAnchor)}
                          label={t(proj.title, lang)}
                          className="text-black hover:text-gray-700 print:text-black print:no-underline"
                          externalHref={proj.externalUrl}
                          externalVisibility={proj.externalLinkVisibility}
                          externalClassName="text-gray-500 hover:text-gray-700"
                          githubHref={proj.githubUrl}
                          githubClassName="text-gray-500 hover:text-gray-700"
                          googlePlayHref={proj.googlePlayUrl}
                          googlePlayClassName="text-gray-500 hover:text-gray-700"
                          appStoreHref={proj.appStoreUrl}
                          appStoreClassName="text-gray-500 hover:text-gray-700"
                        />
                           </h3>
                           <span class="text-[13px] font-semibold text-gray-400 border border-gray-200 px-1.5 py-0.5 rounded-sm">
                             {t(proj.period, lang)}
                           </span>
                         </div>
                         {proj.badge && (
                            <span class="inline-block bg-black text-white px-2 py-[2px] text-[10.5px] font-bold uppercase tracking-wider mb-2">
                               {t(proj.badge, lang)}
                            </span>
                         )}
                      </div>
                      
                      {proj.summary && (
                        <p class="mb-4 whitespace-pre-line text-[14px] text-gray-600 leading-[1.6]">
                          {t(proj.summary, lang)}
                        </p>
                      )}
                      
                      {proj.tech?.length > 0 && (
                        <div class="mb-3 text-[13px] text-gray-500">
                          <span class="font-bold text-black">Tech:</span> {proj.tech.join(', ')}
                        </div>
                      )}
                      
                      <ul class="list-none space-y-1.5 p-0 mb-4">
                        {bullets(proj.highlights, lang).map((line) => (
                          <li class="relative pl-3 text-[14px] text-gray-600 leading-[1.6] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-px before:bg-gray-400">
                            {line}
                          </li>
                        ))}
                      </ul>
                      
                      {proj.results && bullets(proj.results, lang).length > 0 && (
                        <div class="mt-4 pt-3 border-t border-dashed border-gray-200">
                          <ul class="list-none pl-0 space-y-1">
                            {bullets(proj.results, lang).map((line) => (
                              <li class="relative pl-4 text-[13.5px] font-bold text-black leading-[1.6] before:absolute before:left-0 before:top-1.5 before:content-['✓'] before:text-gray-400">
                                {line}
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </section>
            ))
          }

          <!-- TWO COLLUMN INFO -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
             <section>
               <h2 class="mb-6 text-[15px] font-bold text-black border-b-2 border-black pb-2 uppercase tracking-widest">
                 {m.skills}
               </h2>
               <div class="space-y-6">
                 {
                   profile.skillGroups.map((g) => (
                     <div class="break-inside-avoid">
                       <div class="text-[14px] font-bold text-black tracking-wide uppercase mb-1.5">{g.label}</div>
                       <div class="whitespace-pre-line text-[14px] leading-[1.6] text-gray-600">
                         {lang === 'en' ? g.body_en : g.body_ko}
                       </div>
                     </div>
                   ))
                 }
                 {lang === 'en' && profile.languages_note && (
                   <div class="break-inside-avoid mt-8 pt-6 border-t border-gray-200">
                      <div class="text-[14px] font-bold text-black tracking-wide uppercase mb-1.5">{m.languages}</div>
                      <p class="whitespace-pre-line text-[14px] leading-[1.6] text-gray-600">
                        {t(profile.languages_note, lang)}
                      </p>
                   </div>
                 )}
               </div>
             </section>

             <aside class="space-y-12 print:ml-0 print:mt-10">
               <section>
                 <h2 class="mb-6 text-[15px] font-bold text-black border-b-2 border-black pb-2 uppercase tracking-widest">
                   {m.education}
                 </h2>
                 <div class="space-y-5">
                   {
                     profile.education.map((ed) => (
                       <div class="break-inside-avoid group border-l-2 border-transparent hover:border-black pl-3 ml-[-14px] transition-colors">
                         <div class="text-[14.5px] font-bold text-black mb-0.5">{t(ed.school, lang)}</div>
                         <div class="text-[13.5px] text-gray-600 mb-0.5">{t(ed.degree, lang)}</div>
                         <div class="text-[12px] text-gray-400 font-bold tracking-widest uppercase">{t(ed.period, lang)}</div>
                       </div>
                     ))
                   }
                 </div>
               </section>

               <section>
                 <h2 class="mb-6 text-[15px] font-bold text-black border-b-2 border-black pb-2 uppercase tracking-widest">
                   {m.activities}
                 </h2>
                 <div class="space-y-5">
                   {
                     profile.activities.map((a) => (
                       <div class="break-inside-avoid">
                         <div class="text-[14px] font-bold text-black mb-0.5">{t(a.title, lang)}</div>
                         <div class="text-[12px] text-gray-400 font-bold tracking-widest uppercase">{t(a.period, lang)}</div>
                         {a.description && (
                           <p class="mt-1.5 text-[12.5px] leading-relaxed text-gray-600 whitespace-pre-line">
                             {t(a.description, lang)}
                           </p>
                         )}
                         {a.externalUrl && a.externalLabel && (
                           <a
                             href={a.externalUrl}
                             target="_blank"
                             rel="noreferrer"
                             class="mt-1 inline-flex items-center text-[11.5px] font-semibold text-gray-700 hover:underline"
                           >
                             [{t(a.externalLabel, lang)}]
                           </a>
                         )}
                       </div>
                     ))
                   }
                 </div>
               </section>

               {profile.awards.length > 0 && (
                 <section>
                   <h2 class="mb-6 text-[15px] font-bold text-black border-b-2 border-black pb-2 uppercase tracking-widest">
                     {m.awards}
                   </h2>
                   <div class="space-y-5">
                     {
                       profile.awards.map((aw) => (
                         <div class="break-inside-avoid">
                           <div class="text-[14px] font-bold text-black mb-0.5">{aw.title}</div>
                           {aw.subtitle && (
                             <div class="text-[13px] text-gray-500">{t(aw.subtitle, lang)}</div>
                           )}
                         </div>
                       ))
                     }
                   </div>
                 </section>
               )}
             </aside>
          </div>
          
        </div>
      </section>
      </div>
    </article>
  </body>
</html>


