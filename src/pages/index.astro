---
import { baseUrlJoin } from '@/lib/base-url';
import CommonHead from '@/components/CommonHead.astro';

const resumeKo = baseUrlJoin('ko');
const resumeEn = baseUrlJoin('en');
const portfolioKo = baseUrlJoin('ko', 'portfolio');
const portfolioEn = baseUrlJoin('en', 'portfolio');
---
<!DOCTYPE html>
<html lang="ko">
  <head>
    <CommonHead title="teddy-resume" />
    <meta http-equiv="refresh" content={`0;url=${resumeKo}`} />
  </head>
  <body class="min-h-screen bg-gray-100 print:bg-transparent p-8 font-sans text-sm text-gray-600">
    <p class="text-center">
      <a class="font-medium text-indigo-800 underline" href={resumeKo}>한국어 이력서</a>
      <span class="mx-2 text-gray-400">·</span>
      <a class="font-medium text-indigo-800 underline" href={resumeEn}>English</a>
      <span class="mx-2 text-gray-400">·</span>
      <a class="font-medium text-indigo-800 underline" href={portfolioKo}>포트폴리오</a>
      <span class="mx-2 text-gray-400">·</span>
      <a class="font-medium text-indigo-800 underline" href={portfolioEn}>Portfolio EN</a>
    </p>
  </body>
</html>
