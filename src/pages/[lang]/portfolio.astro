---
import CommonHead from '@/components/CommonHead.astro';
import LanguageSwitcher from '@/components/LanguageSwitcher.astro';
import MermaidDiagram from '@/components/MermaidDiagram.astro';
import PortfolioReferenceGallery from '@/components/PortfolioReferenceGallery.astro';
import PortfolioProjectTitleLink from '@/components/PortfolioProjectTitleLink.astro';
import { baseUrlJoin } from '@/lib/base-url';
import { normalizeLang, SUPPORTED_LANGS } from '@/lib/i18n';
import { kakaoPiccomaPortfolio, portfolioText } from '@/lib/portfolio-content';
import { loadResume } from '@/lib/load-resume';
import type { Lang } from '@/lib/resume-types';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const lang: Lang = normalizeLang(Astro.params.lang);
const profile = loadResume();
const content = kakaoPiccomaPortfolio;
const resumeUrl = baseUrlJoin(lang);
const portfolioLangLinks = SUPPORTED_LANGS.map((candidate) => ({
  lang: candidate,
  href: baseUrlJoin(candidate, content.slug),
}));
const orderedTitles = [
  '멀티 벤더 결제 시스템 및 정산 안정화',
  '카카오 T 계정 링크 및 결제수단 등록',
  '차량 등록 / 차량 고유 키 자동 매핑 / PnC(Plug & Charge) 인증',
  '통합 프로모션(쿠폰/포인트) 플랫폼 구축 및 고도화',
  '개발 생산성 자동화 및 DevOps 개선',
  '프라이싱 플랫폼: 상품 관리 시스템과 프로모션 서비스',
  '멤버십/마일리지 서비스 이관 및 고도화',
  'Commit Map',
];
const getProjectOrder = (title: string) => {
  const index = orderedTitles.indexOf(title);
  return index === -1 ? orderedTitles.length : index;
};
const projects = [...content.projects].sort(
  (a, b) => getProjectOrder(a.title.ko) - getProjectOrder(b.title.ko),
);
const hasDiagrams = projects.some((project) => (project.diagrams?.length ?? 0) > 0);

const roleFocus = content.roleFocus.map((item) => portfolioText(item, lang));
const engineeringThemes = [
  lang === 'ko'
    ? {
        title: '처음부터 크게 나누지 않기',
        body: '처음에는 단순하게 두고, 필요해질 때만 경계를 키웠습니다.',
      }
    : {
        title: 'Avoid over-sizing upfront',
        body: 'Flows start simple and grow only when the work demands it.',
      },
  lang === 'ko'
    ? {
        title: '문제 지점을 보강하되 원인을 구조적으로 개선하기',
        body: '락, 재시도, 복구는 실제로 문제 난 구간부터 붙이되, 가능하면 근본 원인을 원천 개선하는 방향으로 리팩토링하는 편입니다.',
      }
    : {
        title: 'Reinforce pain points, then fix the root cause',
        body: 'I start with locks, retries, and recovery where production pain shows up, but prefer refactors that remove the underlying cause at the source whenever possible.',
      },
  lang === 'ko'
    ? {
        title: '벤더와 정책은 늘어날 때 추상화하기',
        body: '종류가 늘어날 때 공통 계층을 만들고, 그전엔 단순하게 유지했습니다.',
      }
    : {
        title: 'Abstract when variation grows',
        body: 'Shared layers were added only after vendor and policy variation started to grow.',
      },
  lang === 'ko'
    ? {
        title: '반복되면 자동화하기',
        body: '문서, QA 배포, 리뷰 보조는 반복 비용이 커질 때 자동화했습니다.',
      }
    : {
        title: 'Automate repeated work',
        body: 'Documentation, QA delivery, and review support were automated once repetition became expensive.',
      },
];
const sectionLabels =
  lang === 'ko'
    ? {
        intro: '소개',
        index: '목차',
        background: '설계 배경',
        implementation: '핵심 구현',
        outcomes: '운영 결과',
        note: '강조 포인트',
        summary: 'Engineering Profile',
        interview: '실무에서 일한 방식',
        prompts: '엔지니어링 관점',
        diagrams: 'Mermaid로 보는 핵심 구조',
          linked: '이력서 연결 지점',
          references: '참고 화면',
          referenceView: 'Preview',
          referenceExpand: '이미지 클릭 시 확대',
          referenceClose: '닫기',
          referenceVisit: '서비스 보기',
        }
      : {
          intro: 'Introduction',
        index: 'Contents',
        background: 'Design Context',
        implementation: 'Core Implementation',
        outcomes: 'Operational Outcomes',
        note: 'Key Point',
        summary: 'Engineering Profile',
        interview: 'How I Worked In Practice',
        prompts: 'Engineering Lens',
        diagrams: 'Architecture Snapshot',
          linked: 'Resume Link Points',
          references: 'Reference Views',
          referenceView: 'Preview',
          referenceExpand: 'Click image to enlarge',
          referenceClose: 'Close',
          referenceVisit: 'Open service',
        };
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <CommonHead title={portfolioText(content.title, lang)} lang={lang} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Sans+KR:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    {hasDiagrams && (
      <>
        <style is:global>
          {`
            :root {
              color-scheme: light;
            }

            .portfolio-mermaid svg {
              height: auto;
              max-width: 100%;
            }

            .portfolio-mermaid .label,
            .portfolio-mermaid .messageText,
            .portfolio-mermaid .nodeLabel,
            .portfolio-mermaid .edgeLabel {
              font-family: "IBM Plex Sans KR", "IBM Plex Sans", sans-serif !important;
            }
          `}
        </style>
        <script type="module" is:inline>
          const mermaidModule = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
          const mermaid = mermaidModule.default;
          const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
          const getHashTarget = () => {
            const rawHash = window.location.hash?.slice(1);
            if (!rawHash) return null;
            const hash = decodeURIComponent(rawHash);
            return document.getElementById(hash);
          };
          const scrollToHashTarget = (behavior = 'smooth') => {
            const target = getHashTarget();
            if (!target) return;
            target.scrollIntoView({ behavior, block: 'start' });
          };
          const alignHashAfterLayout = async () => {
            if (!window.location.hash) return;
            await sleep(40);
            scrollToHashTarget('auto');
            await sleep(120);
            scrollToHashTarget('smooth');
          };

          mermaid.initialize({
            startOnLoad: false,
            securityLevel: 'loose',
            theme: 'base',
            flowchart: {
              curve: 'basis',
              htmlLabels: true,
              useMaxWidth: true,
            },
            sequence: {
              useMaxWidth: true,
            },
            themeVariables: {
              fontFamily: 'IBM Plex Sans KR, IBM Plex Sans, sans-serif',
              primaryColor: '#dff2ff',
              primaryTextColor: '#0f172a',
              primaryBorderColor: '#0f4c81',
              secondaryColor: '#eef7fb',
              tertiaryColor: '#f8fbfe',
              lineColor: '#3b556b',
              clusterBkg: '#f1f7fb',
              clusterBorder: '#acc6d7',
              actorBkg: '#e8f4ff',
              actorBorder: '#0f4c81',
              noteBkg: '#edf9f3',
              noteBorderColor: '#2f6f57',
              edgeLabelBackground: '#f8fbfe',
            },
          });

          const elements = Array.from(document.querySelectorAll('.js-mermaid'));

          for (const [index, element] of elements.entries()) {
            const source = element.textContent?.trim();
            if (!source) continue;

            try {
              const renderId = `portfolio-mermaid-${index}`;
              const { svg, bindFunctions } = await mermaid.render(renderId, source);
              const wrapper = document.createElement('div');
              wrapper.innerHTML = svg;
              const svgElement = wrapper.firstElementChild;

              if (svgElement) {
                element.replaceWith(svgElement);
                bindFunctions?.(svgElement);
              }
            } catch (error) {
              console.error('Mermaid render failed:', error);
              element.classList.add('whitespace-pre-wrap', 'text-rose-700');
              element.textContent = source;
            }
          }

          if (document.fonts?.ready) {
            try {
              await document.fonts.ready;
            } catch (error) {
              console.warn('Font readiness check failed:', error);
            }
          }

          await alignHashAfterLayout();
          window.addEventListener('hashchange', () => {
            requestAnimationFrame(() => scrollToHashTarget('smooth'));
          });
        </script>
      </>
    )}
  </head>
  <body
    class="min-h-screen bg-[#edf4f8] text-slate-900 antialiased"
    style="font-family: 'IBM Plex Sans KR', 'IBM Plex Sans', sans-serif;"
  >
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,#d8edff_0%,transparent_28%),radial-gradient(circle_at_top_right,#d7f4ef_0%,transparent_24%),linear-gradient(180deg,#edf4f8_0%,#f7fbfd_100%)]"></div>
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 opacity-[0.08] [background-image:linear-gradient(to_right,#0f172a_1px,transparent_1px),linear-gradient(to_bottom,#0f172a_1px,transparent_1px)] [background-size:30px_30px]"></div>

    <main class="mx-auto flex max-w-7xl flex-col gap-8 px-4 py-6 sm:px-6 lg:px-10 lg:py-10">
      <nav class="flex flex-wrap items-center justify-between gap-3 rounded-[1.4rem] border border-slate-900/10 bg-white/70 px-4 py-4 text-sm shadow-[0_20px_60px_-42px_rgba(15,23,42,0.35)] backdrop-blur-sm">
        <div class="flex flex-wrap items-center gap-3 text-slate-600">
          <span class="rounded-full border border-sky-800/15 bg-sky-50 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-sky-800">
            {lang === 'ko' ? 'Portfolio' : 'Portfolio'}
          </span>
          <span class="font-medium text-slate-700">{profile.name}</span>
        </div>
        <div class="flex flex-wrap items-center gap-4">
          <a class="font-medium text-slate-600 transition hover:text-slate-900" href={resumeUrl}>
            {lang === 'ko' ? '이력서 보기' : 'View resume'}
          </a>
          <LanguageSwitcher
            lang={lang}
            links={portfolioLangLinks}
            linkClass="text-sky-900 hover:text-sky-700 hover:underline"
            activeClass="text-slate-900"
          />
        </div>
      </nav>

      <section class="grid gap-8 rounded-[2rem] border border-slate-900/10 bg-white/74 p-6 shadow-[0_30px_80px_-44px_rgba(15,23,42,0.4)] backdrop-blur-sm lg:grid-cols-[1.18fr_0.82fr] lg:p-8">
        <div class="space-y-8">
          <div class="space-y-4">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-800">
              {portfolioText(content.eyebrow, lang)}
            </p>
            <h1 class="max-w-4xl text-4xl font-semibold tracking-[-0.04em] text-slate-950 sm:text-5xl lg:text-[3.7rem]">
              {portfolioText(content.title, lang)}
            </h1>
            <p class="max-w-3xl text-base leading-8 text-slate-700 sm:text-lg">
              {portfolioText(content.intro, lang)}
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-3">
            <div class="rounded-[1.25rem] border border-slate-900/10 bg-slate-50/90 px-4 py-4">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
                {lang === 'ko' ? 'Projects' : 'Projects'}
              </p>
              <p class="mt-2 text-2xl font-semibold text-slate-950">{projects.length}</p>
            </div>
            <div class="rounded-[1.25rem] border border-slate-900/10 bg-slate-50/90 px-4 py-4">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
                {lang === 'ko' ? 'Primary Stack' : 'Primary Stack'}
              </p>
              <p class="mt-2 text-sm leading-7 text-slate-700">Kotlin / Spring Boot / MySQL</p>
            </div>
            <div class="rounded-[1.25rem] border border-slate-900/10 bg-slate-50/90 px-4 py-4">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
                {lang === 'ko' ? 'Focus' : 'Focus'}
              </p>
              <p class="mt-2 text-sm leading-7 text-slate-700">
                {lang === 'ko' ? '아키텍처, 상태 전이, 운영 복원력' : 'Architecture, state transitions, operational resilience'}
              </p>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            {roleFocus.map((item, index) => (
              <div class="flex gap-3 rounded-[1.15rem] border border-slate-900/10 bg-[#f7fbfe] px-4 py-4">
                <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-sky-100 text-xs font-semibold tracking-[0.02em] text-sky-800">
                  {(index + 1).toString().padStart(2, '0')}
                </span>
                <p class="text-sm leading-7 text-slate-700">{item}</p>
              </div>
            ))}
          </div>
        </div>

        <aside class="rounded-[1.6rem] bg-[linear-gradient(180deg,#0f172a_0%,#162235_100%)] px-6 py-6 text-slate-100 shadow-[0_24px_70px_-38px_rgba(15,23,42,0.7)]">
          <div class="space-y-6">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-200/80">
                {sectionLabels.summary}
              </p>
              <p class="mt-2 text-2xl font-semibold text-white">
                {lang === 'ko' ? profile.name : profile.name_en}
              </p>
              <p class="mt-1 text-sm text-slate-300">{profile.contact.email}</p>
            </div>
            <div class="rounded-[1.2rem] border border-white/10 bg-white/5 px-4 py-4">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-200/80">
                {sectionLabels.interview}
              </p>
              <p class="mt-2 text-sm leading-6 text-slate-300">
                {lang === 'ko'
                  ? '실제 서비스 환경에서 문제를 풀어온 방식과 설계 판단의 기준을 정리했습니다.'
                  : 'A concise summary of the problem-solving approach and design judgment applied across real service environments.'}
              </p>
              <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-2">
                {engineeringThemes.map((theme, index) => (
                  <article class="rounded-[1rem] border border-white/10 bg-white/[0.06] px-3 py-3">
                    <div class="flex items-start gap-2.5">
                      <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-sky-200/20 bg-sky-300/10 text-[10px] font-semibold tracking-[0.08em] text-sky-100">
                        {(index + 1).toString().padStart(2, '0')}
                      </span>
                      <div>
                        <p class="text-sm font-semibold leading-5 text-white">{theme.title}</p>
                        <p class="mt-1 text-[13px] leading-5 text-slate-300">{theme.body}</p>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </div>
        </aside>
      </section>

      <section class="grid gap-8 lg:grid-cols-[16rem_minmax(0,1fr)]">
        <aside class="hidden lg:block">
          <div class="sticky top-8 space-y-6 rounded-[1.4rem] border border-slate-900/10 bg-white/68 p-5 shadow-[0_22px_70px_-44px_rgba(15,23,42,0.35)] backdrop-blur-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-800">
              {sectionLabels.index}
            </p>
            <ol class="space-y-3 border-l border-slate-900/10 pl-4 text-sm leading-6 text-slate-600">
              {projects.map((project, index) => (
                <li>
                  <a href={`#${project.slug}`} class="block rounded-xl px-2 py-2 transition hover:bg-slate-50 hover:text-slate-950">
                    <span class="block text-xs font-semibold tracking-[0.18em] text-sky-800/70">
                      {(index + 1).toString().padStart(2, '0')}
                    </span>
                    <span class="mt-1 block font-medium">
                      {portfolioText(project.indexLabel ?? project.title, lang)}
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          </div>
        </aside>

        <section class="space-y-6">
        {projects.map((project, index) => (
          <article id={project.slug} class="grid gap-6 scroll-mt-8 rounded-[1.75rem] border border-slate-900/10 bg-white/78 p-6 shadow-[0_28px_80px_-52px_rgba(15,23,42,0.38)] backdrop-blur-sm lg:grid-cols-[7rem_minmax(0,1fr)] lg:p-7">
            <div class="flex items-start gap-3 lg:block">
              <span class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-800">
                {lang === 'ko' ? 'Project' : 'Project'}
              </span>
              <p class="mt-1 inline-flex h-14 w-14 items-center justify-center rounded-[1rem] border border-slate-900/10 bg-slate-50 text-2xl font-semibold leading-none text-slate-500 lg:mt-3">
                {(index + 1).toString().padStart(2, '0')}
              </p>
            </div>

            <div class="space-y-10">
              {(() => {
                const hasReferenceImages = (project.referenceImages?.length ?? 0) > 0;
                const useSplitReferenceContext =
                  hasReferenceImages && project.referenceLayout === 'split-with-context';
                const detailGridClass = useSplitReferenceContext
                  ? 'grid gap-8'
                  : 'grid gap-8 xl:grid-cols-2';

                return (
                  <>
              <header class="space-y-4">
                <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500">
                  <span>{portfolioText(project.company, lang)}</span>
                  <span class="text-slate-300">/</span>
                  <span>{portfolioText(project.period, lang)}</span>
                </div>
                <div class="space-y-3">
                  <h2 class="text-3xl font-semibold tracking-[-0.03em] text-slate-950 sm:text-[2.15rem]">
                    <PortfolioProjectTitleLink
                      label={portfolioText(project.title, lang)}
                      externalHref={project.externalUrl}
                      className="text-slate-950"
                      externalClassName="text-slate-400 hover:text-sky-700"
                    />
                  </h2>
                  <p class="text-base font-medium leading-7 text-slate-700">
                    {portfolioText(project.roleLabel, lang)}
                  </p>
                  <p class="max-w-4xl text-base leading-8 text-slate-700">
                    {portfolioText(project.summary, lang)}
                  </p>
                </div>
                {project.subsections && project.subsections.length > 0 && (
                  <div class="grid gap-3 md:grid-cols-2">
                    {project.subsections.map((subsection) => (
                      <section
                        id={subsection.id}
                        class="scroll-mt-24 rounded-[1.1rem] border border-slate-900/10 bg-[#f8fbfd] px-4 py-4"
                      >
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-sky-800">
                          {sectionLabels.linked}
                        </p>
                        <h3 class="mt-2 text-sm font-semibold leading-6 text-slate-900">
                          {portfolioText(subsection.title, lang)}
                        </h3>
                        <p class="mt-2 text-sm leading-7 text-slate-600">
                          {portfolioText(subsection.description, lang)}
                        </p>
                      </section>
                    ))}
                  </div>
                )}
                <div class="flex flex-wrap gap-2">
                  {project.tech.map((item) => (
                    <span class="rounded-full border border-slate-900/10 bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-700">
                      {item}
                    </span>
                  ))}
                </div>
              </header>

              {hasReferenceImages && useSplitReferenceContext ? (
                <div class="grid gap-8 xl:grid-cols-[minmax(0,0.72fr)_minmax(0,1fr)] xl:items-start">
                  <PortfolioReferenceGallery
                    galleryKey={project.slug}
                    sectionTitle={sectionLabels.references}
                    viewLabel={sectionLabels.referenceView}
                    expandLabel={sectionLabels.referenceExpand}
                    closeLabel={sectionLabels.referenceClose}
                    externalLinkLabel={sectionLabels.referenceVisit}
                    items={project.referenceImages!.map((item) => ({
                      src: item.src,
                      href: item.href,
                      alt: portfolioText(item.alt, lang),
                      title: portfolioText(item.title, lang),
                      caption: item.caption ? portfolioText(item.caption, lang) : undefined,
                    }))}
                  />

                  <section class="rounded-[1.35rem] border border-slate-900/10 bg-[#f9fbfd] p-5">
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-800">
                        {sectionLabels.background}
                      </p>
                      <p class="mt-3 text-sm leading-7 text-slate-700">
                        {portfolioText(project.challenge, lang)}
                      </p>
                    </div>

                    <div class="mt-6 border-t border-slate-900/10 pt-4">
                      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-800">
                        {sectionLabels.note}
                      </p>
                      <p class="mt-3 text-sm leading-7 text-slate-600">
                        {portfolioText(project.note, lang)}
                      </p>
                    </div>
                  </section>
                </div>
              ) : hasReferenceImages ? (
                <PortfolioReferenceGallery
                  galleryKey={project.slug}
                  sectionTitle={sectionLabels.references}
                  viewLabel={sectionLabels.referenceView}
                  expandLabel={sectionLabels.referenceExpand}
                  closeLabel={sectionLabels.referenceClose}
                  externalLinkLabel={sectionLabels.referenceVisit}
                  items={project.referenceImages!.map((item) => ({
                    src: item.src,
                    href: item.href,
                    alt: portfolioText(item.alt, lang),
                    title: portfolioText(item.title, lang),
                    caption: item.caption ? portfolioText(item.caption, lang) : undefined,
                  }))}
                />
              ) : null}

              <div class={detailGridClass}>
                {!useSplitReferenceContext && (
                  <section class="rounded-[1.35rem] border border-slate-900/10 bg-[#f9fbfd] p-5">
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-800">
                        {sectionLabels.background}
                      </p>
                      <p class="mt-3 text-sm leading-7 text-slate-700">
                        {portfolioText(project.challenge, lang)}
                      </p>
                    </div>

                    <div class="mt-6 border-t border-slate-900/10 pt-4">
                      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-800">
                        {sectionLabels.note}
                      </p>
                      <p class="mt-3 text-sm leading-7 text-slate-600">
                        {portfolioText(project.note, lang)}
                      </p>
                    </div>
                  </section>
                )}

                <section class="rounded-[1.35rem] border border-slate-900/10 bg-[#f9fbfd] p-5">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-800">
                    {sectionLabels.implementation}
                  </p>
                  <ul class="mt-3 space-y-3">
                    {project.actions.map((item) => (
                      <li class="relative pl-5 text-sm leading-7 text-slate-700 before:absolute before:left-0 before:top-3 before:h-px before:w-3 before:bg-sky-700">
                        {portfolioText(item, lang)}
                      </li>
                    ))}
                  </ul>
                </section>

                {project.engineeringViews && project.engineeringViews.length > 0 && (
                  <section class="rounded-[1.35rem] border border-slate-900/10 bg-[linear-gradient(180deg,#eef7fb_0%,#f7fbfe_100%)] p-5 xl:col-span-2">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-800">
                      {sectionLabels.prompts}
                    </p>
                    <ul class="mt-3 grid gap-3 md:grid-cols-2">
                      {project.engineeringViews.map((item) => (
                        <li class="rounded-[1rem] border border-slate-900/10 bg-white/70 px-4 py-4 text-sm leading-7 text-slate-700">
                          {portfolioText(item, lang)}
                        </li>
                      ))}
                    </ul>
                  </section>
                )}
              </div>

              {project.diagrams && project.diagrams.length > 0 && (
                <section class="rounded-[1.45rem] border border-slate-900/10 bg-[linear-gradient(180deg,#f7fbfe_0%,#f1f7fb_100%)] p-5">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-800">
                    {sectionLabels.diagrams}
                  </p>
                  <div class="mt-4 grid gap-4">
                    {project.diagrams.map((diagram) => (
                      <MermaidDiagram
                        title={portfolioText(diagram.title, lang)}
                        description={portfolioText(diagram.description, lang)}
                        code={diagram.code}
                        exampleTitle={diagram.example ? portfolioText(diagram.example.title, lang) : undefined}
                        exampleSteps={diagram.example
                          ? diagram.example.steps.map((item) => portfolioText(item, lang))
                          : undefined}
                      />
                    ))}
                  </div>
                </section>
              )}

              <section class="rounded-[1.35rem] border border-slate-900/10 bg-slate-50/85 p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-800">
                  {sectionLabels.outcomes}
                </p>
                <ul class="mt-3 grid gap-3 sm:grid-cols-2">
                  {project.outcomes.map((item) => (
                    <li class="rounded-[1rem] border border-slate-900/10 bg-white px-4 py-4 text-sm font-medium leading-7 text-slate-800">
                      {portfolioText(item, lang)}
                    </li>
                  ))}
                </ul>
              </section>
                  </>
                );
              })()}
            </div>
          </article>
        ))}
        </section>
      </section>

    </main>
  </body>
</html>
