<script>
  /**
   * Automatic Pagination Logic for A4 Resume
   */
  const A4_HEIGHT_MM = 297;
  const DPI = 96;
  const A4_HEIGHT_PX = Math.floor((A4_HEIGHT_MM * DPI) / 25.4); // ~1122.5px

  function paginate() {
    const containers = document.querySelectorAll('.auto-paginate:not([data-paginated="true"])');
    
    containers.forEach((container) => {
      const contentWrapper = container.querySelector('.paginate-content');
      if (!contentWrapper) return;

      const children = Array.from(contentWrapper.children).filter(child => !child.classList.contains('print-spacer'));
      const pages = [];
      let currentPageItems = [];

      // Adjusted Margin to 12mm (~45.4px)
      const MARGIN_PX = 45.4; 
      const SAFE_BUFFER = 5; 
      const isCreative = (container as HTMLElement).dataset.template === 'creative';
      let currentHeight = MARGIN_PX; 

      children.forEach((child) => {
        const isHeader = child.tagName === 'H2' && child.classList.contains('print:break-before-page');
        const childHeight = (child as HTMLElement).offsetHeight;
        const computedStyle = window.getComputedStyle(child as HTMLElement);
        const childMargin = parseFloat(computedStyle.marginTop) + parseFloat(computedStyle.marginBottom);
        const fullItemHeight = childHeight + childMargin;

        const bottomLimit = isCreative ? A4_HEIGHT_PX - SAFE_BUFFER : A4_HEIGHT_PX - MARGIN_PX - SAFE_BUFFER;
        const shouldBreak = (isHeader && currentPageItems.length > 0) || 
                           (currentHeight + fullItemHeight > bottomLimit && currentPageItems.length > 0);

        if (shouldBreak) {
          pages.push(currentPageItems);
          currentPageItems = [child];
          currentHeight = MARGIN_PX + fullItemHeight;
        } else {
          currentPageItems.push(child);
          currentHeight += fullItemHeight;
        }
      });
      
      if (currentPageItems.length > 0) pages.push(currentPageItems);

      if (pages.length > 0) {
        const fragment = document.createDocumentFragment();
        const originalClasses = container.className.replace('auto-paginate', '').trim();
        const originalContentClasses = contentWrapper.className;

        pages.forEach((pageItems, index) => {
          const pageDiv = document.createElement('div');
          pageDiv.className = originalClasses + ' paginated-page' + (index > 0 ? ' print:break-before-page print:mt-0' : '');
          pageDiv.dataset.paginated = 'true';
          
          const innerDiv = document.createElement('div');
          innerDiv.className = originalContentClasses;
          
          // Use 12mm Top Spacer
          const topSpacer = document.createElement('div');
          topSpacer.className = 'print-spacer h-[12mm] w-full shrink-0';
          innerDiv.appendChild(topSpacer);
          
          pageItems.forEach(item => innerDiv.appendChild(item));

          // Use 12mm Bottom Spacer (Skip for creative template)
          if ((container as HTMLElement).dataset.template !== 'creative') {
            const bottomSpacer = document.createElement('div');
            bottomSpacer.className = 'print-spacer h-[12mm] w-full shrink-0 mt-auto';
            innerDiv.appendChild(bottomSpacer);
          }
          
          pageDiv.appendChild(innerDiv);
          fragment.appendChild(pageDiv);
        });

        const parent = container.parentElement;
        if (parent) {
          parent.insertBefore(fragment, container);
          parent.removeChild(container);
        }
      }
    });
  }

  window.addEventListener('load', () => {
    paginate();
    setTimeout(paginate, 500);
    setTimeout(paginate, 1500);
  });
</script>

<style is:global>
  .paginated-page {
    background: white;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    min-height: 297mm;
    display: flex;
    flex-direction: column;
  }

  @media print {
    .print\:break-before-page {
      break-before: page !important;
    }
    .paginated-page {
      height: 297mm !important;
      min-height: 297mm !important;
      max-height: 297mm !important;
      box-shadow: none !important;
      margin: 0 !important;
      overflow: hidden !important;
    }
  }
</style>
