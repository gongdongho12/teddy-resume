---
interface Props {
  items: string[];
  class?: string;
  itemClass?: string;
}

const { items, class: className = '', itemClass = '' } = Astro.props as Props;
---

<div class:list={['mt-2 flex flex-wrap gap-2', className]}>
  {items.map((item) => (
    <span
      class:list={[
        'inline-flex items-center rounded-full border border-slate-200 bg-white px-2.5 py-1 text-[12px] font-semibold leading-none text-slate-700 shadow-[0_1px_0_rgba(15,23,42,0.03)]',
        itemClass,
      ]}
    >
      {item}
    </span>
  ))}
</div>
