---
import type { Lang } from '@/lib/resume-types';

interface Props {
  lang: Lang;
  accentClass?: string;
}

const {
  lang,
  accentClass = 'text-[#0f3460]',
} = Astro.props;

const hintLead = lang === 'ko' ? '인쇄' : 'Print';
const hintRest =
  lang === 'ko'
    ? ' 시 배경 그래픽 포함 + 여백 없음 설정으로 깔끔하게 출력 가능'
    : ' tip: Background Graphics + Margins None';
const panelTitle = lang === 'ko' ? '권장 인쇄 설정' : 'Recommended Print Settings';
const panelSubtitle =
  lang === 'ko'
    ? '마우스를 올리면 예시 이미지를 볼 수 있어요'
    : 'Hover to preview the recommended setup';
const panelBadge = lang === 'ko' ? '예시' : 'Preview';
const panelCaption =
  lang === 'ko'
    ? '브라우저 인쇄 창에서 배경 그래픽을 포함하고 여백을 없음으로 맞추면 현재 레이아웃을 가장 깔끔하게 저장하거나 출력할 수 있습니다.'
    : 'Turn on background graphics and set margins to none in the browser print dialog for the cleanest PDF or printed layout.';
const imageAlt =
  lang === 'ko'
    ? '여백 없음 옵션이 강조된 브라우저 인쇄 설정 예시'
    : 'Browser print settings preview with margins set to none';
---

<div class="group relative">
  <button
    type="button"
    class="inline-flex cursor-help items-center gap-2 rounded-full border border-slate-200 bg-white/90 px-3 py-1.5 text-[13px] shadow-sm transition duration-200 hover:-translate-y-0.5 hover:border-[#0f3460]/30 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-[#0f3460]/20"
    aria-label={panelTitle}
  >
    <span class:list={['font-semibold', accentClass]} data-print-hint-lead data-lang={lang}>{hintLead}</span>
    <span class="text-gray-500" data-print-hint-rest data-lang={lang}>{hintRest}</span>
    <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-slate-100 text-[11px] font-bold text-slate-500">
      ?
    </span>
  </button>

  <div class="pointer-events-none absolute right-0 top-full z-30 mt-3 w-[24rem] sm:w-[26rem] max-w-[calc(100vw-4rem)] translate-y-1 opacity-0 transition duration-200 ease-out group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:translate-y-0 group-focus-within:opacity-100">
    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-2xl ring-1 ring-slate-900/5">
      <div class="flex items-start justify-between gap-3 border-b border-slate-100 bg-slate-50 px-4 py-3">
        <div>
          <p class:list={['text-[11px] font-semibold uppercase tracking-[0.18em]', accentClass]}>
            {panelTitle}
          </p>
          <p class="mt-1 text-xs text-slate-500">{panelSubtitle}</p>
        </div>
        <span class:list={['rounded-full bg-white px-2 py-1 text-[11px] font-semibold shadow-sm', accentClass]}>
          {panelBadge}
        </span>
      </div>

      <img
        src="/images/print-settings-preview.svg"
        alt={imageAlt}
        class="block w-full border-b border-slate-100 bg-slate-100"
        loading="lazy"
      />

      <p class="px-4 py-3 text-xs leading-relaxed text-slate-600">
        {panelCaption}
      </p>
    </div>
  </div>
</div>
