---
import type { Lang, ResumeProfile } from '../../lib/resume-types';
import { messages } from '../../lib/messages';
import { t, bullets } from '../../lib/localize';
import { baseUrlJoin } from '../../lib/base-url';
import TemplateSelector from '../../components/TemplateSelector.astro';

interface Props {
  lang: Lang;
  profile: ResumeProfile;
}

const { lang, profile } = Astro.props;
const m = messages(lang);
const other = lang === 'ko' ? 'en' : 'ko';
const otherLangUrl = baseUrlJoin(other);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{m.docTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-gray-100 font-sans text-sm leading-relaxed text-gray-800 antialiased">
    <TemplateSelector lang={lang} currentTemplate="default" />
    
    <div
      class="print:hidden mx-auto flex max-w-4xl flex-wrap items-center justify-end gap-3 px-4 pb-2 pt-4 text-sm"
    >
      <span class="text-gray-500">{m.printHint}</span>
      <a href={otherLangUrl} class="font-semibold text-indigo-900 hover:underline">{m.navOther}</a>
    </div>

    <article
      class="mx-auto mb-12 max-w-4xl overflow-hidden rounded-lg bg-white shadow-lg print:mb-0 print:shadow-none print:overflow-visible"
    >
      <header
        class="flex flex-col gap-8 bg-gradient-to-br from-[#1a1a2e] to-[#0f3460] p-8 text-white md:flex-row md:items-start md:justify-between md:p-12 print:px-9 print:py-8"
      >
        <div class="min-w-0 flex-1">
          {
            lang === 'en' ? (
              <>
                <h1 class="mb-1 text-4xl font-black tracking-tight md:text-5xl">
                  {profile.name_en}
                </h1>
                <p class="mb-4 text-sm text-white/80">{profile.name}</p>
              </>
            ) : (
              <h1 class="mb-4 text-4xl font-black tracking-tight md:text-5xl">{profile.name}</h1>
            )
          }
          <p class="max-w-xl whitespace-pre-line text-[15px] text-white/90">
            {t(profile.summary, lang)}
          </p>
        </div>
        <address
          class="shrink-0 not-italic md:text-right [&_a]:text-blue-200 [&_a]:hover:underline"
        >
          <div>{profile.contact.phone}</div>
          <div>
            <a href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a>
          </div>
          <div>
            <a href={profile.contact.github_url} target="_blank" rel="noreferrer"
              >{profile.contact.github_label}</a
            >
          </div>
          <div>
            <a href={profile.contact.linkedin_url} target="_blank" rel="noreferrer"
              >{profile.contact.linkedin_label}</a
            >
          </div>
        </address>
      </header>

      <div class="p-8 md:p-14 print:px-9 print:py-8">
        <div class="grid grid-cols-1 gap-10 md:grid-cols-[1fr_17.5rem]">
          <div class="min-w-0 space-y-10">
            <section class="break-inside-avoid">
              <h2
                class="mb-7 border-b-2 border-[#0f3460] pb-2 text-xs font-bold uppercase tracking-[0.2em] text-[#0f3460]"
              >
                {m.experience}
              </h2>
              <div class="space-y-7">
                {
                  profile.experience.map((exp) => (
                    <div class="break-inside-avoid">
                      <div class="mb-1 flex flex-wrap items-baseline justify-between gap-2">
                        <h3 class="text-base font-bold text-[#1a1a2e]">{t(exp.company, lang)}</h3>
                        <span class="whitespace-nowrap text-xs text-gray-500">
                          {t(exp.period, lang)}
                        </span>
                      </div>
                      {exp.role && (
                        <p class="mb-1 text-[13px] text-gray-500">{t(exp.role, lang)}</p>
                      )}
                      {lang === 'en' && exp.location_en && (
                        <p class="mb-1 text-[13px] text-gray-500">{exp.location_en}</p>
                      )}
                      <p class="whitespace-pre-line text-[13px] text-gray-800">
                        {t(exp.description, lang)}
                      </p>
                    </div>
                  ))
                }
              </div>
            </section>

            {
              profile.projectSections.map((section) => (
                <section class="break-inside-avoid space-y-6">
                  <h2 class="border-b-2 border-[#0f3460] pb-2 text-xs font-bold uppercase tracking-[0.2em] text-[#0f3460]">
                    {t(section.heading, lang)}
                  </h2>
                  {section.projects.map((proj) => (
                    <div class="break-inside-avoid space-y-3 rounded-r-lg border-l-4 border-[#0f3460] bg-gray-50 p-6">
                      <div class="flex flex-wrap items-baseline justify-between gap-2">
                        <h3 class="text-base font-bold text-[#1a1a2e]">
                          {t(proj.title, lang)}
                          {proj.badge && (
                            <span class="ml-2 inline-block rounded-full bg-rose-500 px-2 py-0.5 align-middle text-[11px] font-bold text-white">
                              {t(proj.badge, lang)}
                            </span>
                          )}
                        </h3>
                        <span class="whitespace-nowrap text-xs text-gray-500">
                          {t(proj.period, lang)}
                        </span>
                      </div>
                      {proj.summary && (
                        <p class="whitespace-pre-line text-[13px] text-gray-600">
                          {t(proj.summary, lang)}
                        </p>
                      )}
                      {proj.tech?.length > 0 && (
                        <div class="flex flex-wrap gap-1.5">
                          {proj.tech.map((tag) => (
                            <span class="rounded-full bg-indigo-50 px-2.5 py-0.5 text-[11px] font-medium text-indigo-800">
                              {tag}
                            </span>
                          ))}
                        </div>
                      )}
                      <ul class="list-none space-y-1 p-0">
                        {bullets(proj.highlights, lang).map((line) => (
                          <li class="relative pl-4 text-[13px] before:absolute before:left-0 before:top-2.5 before:h-1.5 before:w-1.5 before:rounded-full before:bg-[#0f3460]">
                            {line}
                          </li>
                        ))}
                      </ul>
                      {proj.results &&
                        bullets(proj.results, lang).length > 0 && (
                          <div class="pt-2">
                            <p class="mb-2 text-xs font-bold text-[#0f3460]">{m.results}</p>
                            <ul class="list-none space-y-1 p-0">
                              {bullets(proj.results, lang).map((line) => (
                                <li class="relative pl-4 text-[13px] before:absolute before:left-0 before:top-2.5 before:h-1.5 before:w-1.5 before:rounded-full before:bg-[#0f3460]">
                                  {line}
                                </li>
                              ))}
                            </ul>
                          </div>
                        )}
                    </div>
                  ))}
                </section>
              ))
            }

            <section class="break-inside-avoid">
              <h2
                class="mb-6 border-b-2 border-[#0f3460] pb-2 text-xs font-bold uppercase tracking-[0.2em] text-[#0f3460]"
              >
                {m.activities}
              </h2>
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                {
                  profile.activities.map((a) => (
                    <div>
                      <div class="font-medium">{t(a.title, lang)}</div>
                      <div class="text-[11px] text-gray-500">{t(a.period, lang)}</div>
                    </div>
                  ))
                }
              </div>
            </section>
          </div>

          <aside class="min-w-0 space-y-9">
            <section>
              <h2
                class="mb-5 border-b-2 border-[#0f3460] pb-2 text-xs font-bold uppercase tracking-[0.2em] text-[#0f3460]"
              >
                {m.skills}
              </h2>
              <div class="space-y-5">
                {
                  profile.skillGroups.map((g) => (
                    <div>
                      <div class="mb-1.5 text-xs font-bold text-[#1a1a2e]">{g.label}</div>
                      <div class="whitespace-pre-line text-[13px] leading-7 text-gray-800">
                        {lang === 'en' ? g.body_en : g.body_ko}
                      </div>
                    </div>
                  ))
                }
              </div>
            </section>

            <section>
              <h2
                class="mb-5 border-b-2 border-[#0f3460] pb-2 text-xs font-bold uppercase tracking-[0.2em] text-[#0f3460]"
              >
                {m.education}
              </h2>
              <div class="space-y-4">
                {
                  profile.education.map((ed) => (
                    <div>
                      <div class="text-[13px] font-bold text-[#1a1a2e]">{t(ed.school, lang)}</div>
                      <div class="text-xs text-gray-500">{t(ed.degree, lang)}</div>
                      <div class="text-xs text-gray-500">{t(ed.period, lang)}</div>
                    </div>
                  ))
                }
              </div>
            </section>

            <section>
              <h2
                class="mb-5 border-b-2 border-[#0f3460] pb-2 text-xs font-bold uppercase tracking-[0.2em] text-[#0f3460]"
              >
                {m.awards}
              </h2>
              {
                profile.awards.map((aw) => (
                  <div>
                    <div class="text-[13px] font-bold">{aw.title}</div>
                    {aw.subtitle && (
                      <div class="text-xs text-gray-500">{t(aw.subtitle, lang)}</div>
                    )}
                  </div>
                ))
              }
            </section>

            {
              lang === 'en' && profile.languages_note && (
                <section>
                  <h2 class="mb-5 border-b-2 border-[#0f3460] pb-2 text-xs font-bold uppercase tracking-[0.2em] text-[#0f3460]">
                    {m.languages}
                  </h2>
                  <p class="whitespace-pre-line text-xs text-gray-600">
                    {t(profile.languages_note, lang)}
                  </p>
                </section>
              )
            }
          </aside>
        </div>
      </div>
    </article>
  </body>
</html>
