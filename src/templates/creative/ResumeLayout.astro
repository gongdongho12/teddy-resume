---
import CommonHead from '@/components/CommonHead.astro';
import type { Lang, ResumeProfile } from '@/lib/resume-types';
import { messages } from '@/lib/messages';
import { t } from '@/lib/localize';
import { getPortfolioProjectHref } from '@/lib/portfolio-links';
import TemplateSelector from '@/components/TemplateSelector.astro';
import AutoPagination from '@/components/AutoPagination.astro';
import PortfolioProjectTitleLink from '@/components/PortfolioProjectTitleLink.astro';
import ResumeTopBar from '@/components/ResumeTopBar.astro';

interface Props {
  lang: Lang;
  profile: ResumeProfile;
}

const { lang, profile } = Astro.props;
const m = messages(lang);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <CommonHead lang={lang} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;900&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <style>
      @page {
        size: A4;
        margin: 0;
      }
      @media print {
        body > *:not(article) {
          display: none !important;
        }
        article {
          position: absolute;
          top: 0;
          left: 0;
          margin: 0 !important;
          width: 210mm !important;
        }
        body {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
          background-color: white;
        }
        h2.print\:break-before-page {
          break-before: page !important;
        }
      }
    </style>
  </head>
  <body class="min-h-screen bg-gray-100 print:bg-white font-sans text-sm leading-relaxed text-gray-800 antialiased" style="font-family: 'Outfit', 'Noto Sans KR', sans-serif;">
    <TemplateSelector lang={lang} currentTemplate="creative" />
    <AutoPagination />

    <ResumeTopBar
      lang={lang}
      currentTemplate="creative"
      maxWidthClass="max-w-[1000px]"
      containerClass="pb-3 text-[13px]"
      printHintTextClass="text-gray-500"
      showPortfolioLink={true}
      portfolioLinkClass="font-medium text-black hover:underline"
      languageLinkClass="text-black hover:text-teal-900 hover:underline"
      activeLanguageClass="text-teal-900"
      contactToggleLabelClass="text-teal-900"
    />

    <article class="mx-auto flex flex-col gap-4 w-full max-w-[794px] xl:max-w-none xl:flex-row xl:flex-wrap xl:justify-center xl:px-20 print:block print:w-[210mm] mb-10 print:mb-0 transition-all duration-500">

      <div class="flex flex-row min-h-[297mm] print:h-[297mm] print:min-h-[297mm] print:max-h-[297mm] bg-white shadow-md print:shadow-none relative overflow-hidden w-full max-w-[794px] xl:max-w-[794px]">
        <aside class="w-[280px] shrink-0 bg-teal-900 text-teal-50 p-8 flex flex-col gap-8 print:bg-teal-900">
          <div>
            {
              lang === 'en' ? (
                <>
                  <h1 class="mb-1 text-3xl font-black tracking-tight text-white leading-tight">
                    {profile.name_en}
                  </h1>
                  <p class="text-sm text-teal-200">{profile.name}</p>
                </>
              ) : (
                <h1 class="mb-2 text-3xl font-black tracking-tight text-white leading-tight">{profile.name}</h1>
              )
            }
          </div>

          <div data-contact-visibility class="space-y-3.5 text-[12.5px] text-teal-100">
            <div class="flex items-center gap-2.5">
              <svg class="w-4 h-4 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              <span>{profile.contact.phone}</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-4 h-4 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              <a href={`mailto:${profile.contact.email}`} class="hover:text-white transition-colors">{profile.contact.email}</a>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-4 h-4 text-teal-400" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
              <a href={profile.contact.github_url} target="_blank" rel="noreferrer" class="hover:text-white transition-colors">{profile.contact.github_label}</a>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-4 h-4 text-teal-400" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              <a href={profile.contact.linkedin_url} target="_blank" rel="noreferrer" class="hover:text-white transition-colors">{profile.contact.linkedin_label}</a>
            </div>
          </div>

          <div class="space-y-6 mt-4">
            <section>
              <h2 class="mb-4 text-[11px] font-bold uppercase tracking-widest text-teal-400">{m.skills}</h2>
              <div class="space-y-3.5">
                {profile.skillGroups.map((g) => (
                  <div class="break-inside-avoid">
                    <div class="mb-0.5 text-[12px] font-bold text-white uppercase tracking-wider">{g.label}</div>
                    <div class="whitespace-pre-line text-[12px] leading-snug text-teal-100/90 font-medium">
                      {lang === 'en' ? g.body_en : g.body_ko}
                    </div>
                  </div>
                ))}
              </div>
            </section>

            <section>
              <h2 class="mb-4 text-[11px] font-bold uppercase tracking-widest text-teal-400">{m.education}</h2>
              <div class="space-y-4">
                {profile.education.map((ed) => (
                  <div class="break-inside-avoid">
                    <div class="text-[12.5px] font-bold text-white mb-0.5">{t(ed.school, lang)}</div>
                    <div class="text-[12px] text-teal-100 font-medium">{t(ed.degree, lang)}</div>
                    <div class="text-[11px] text-teal-400/80 font-bold tracking-wider mt-1 uppercase">{t(ed.period, lang)}</div>
                  </div>
                ))}
              </div>
            </section>
          </div>
        </aside>

        <main class="flex-1 p-8 bg-white">
          <section class="mb-10">
            <p class="whitespace-pre-line text-[14.5px] text-gray-700 leading-relaxed font-medium">
              {t(profile.summary, lang)}
            </p>
          </section>

          <section class="mb-10">
            <div class="flex items-center gap-4 mb-6">
              <h2 class="text-lg font-bold uppercase tracking-wider text-teal-900 shrink-0">{m.experience}</h2>
              <div class="h-px bg-teal-100 w-full"></div>
            </div>
            <div class="space-y-6">
              {profile.experience.map((exp) => (
                <div class="break-inside-avoid relative pl-5 border-l-2 border-teal-100">
                  <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
                    <h3 class="text-[15.5px] font-bold text-gray-900">
                      <PortfolioProjectTitleLink
                        label={t(exp.company, lang)}
                        className="text-gray-900"
                      />
                    </h3>
                    <span class="whitespace-nowrap text-[12px] font-extrabold text-teal-700 bg-teal-50 px-2 py-0.5 rounded tracking-wide">
                      {t(exp.period, lang)}
                    </span>
                  </div>
                  {exp.role && (
                    <p class="text-[13.5px] font-bold text-gray-700 mb-1.5">{t(exp.role, lang)}</p>
                  )}
                  {exp.descriptionLead?.[lang]?.trim() ? (
                    <>
                      <p class="mb-2 text-[12.5px] text-gray-600 leading-relaxed">
                        {exp.descriptionLead[lang]}
                      </p>
                      <ul class="space-y-1.5 pl-5 text-[12.5px] text-gray-600 leading-relaxed list-disc marker:text-teal-700">
                        {t(exp.description, lang).split('\n').map((line) => line.trim()).filter(Boolean).map((line) => (
                          <li>{line}</li>
                        ))}
                      </ul>
                    </>
                  ) : (
                    <p class="whitespace-pre-line text-[12.5px] text-gray-600 leading-relaxed">
                      {t(exp.description, lang)}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </section>
        </main>
      </div>

      <div class="auto-paginate min-h-[297mm] bg-white shadow-md print:shadow-none overflow-hidden w-full max-w-[794px] xl:max-w-[794px]" data-template="creative">
        <section class="paginate-content px-10 py-0 print:px-[15mm] print:py-0">
          {profile.projectSections.map((section) => (
            <>
              <h2 class="flex items-center gap-4 mb-8 pt-0 print:break-before-page text-xl font-bold uppercase tracking-wider text-teal-900 shrink-0">
                <span class="shrink-0">{t(section.heading, lang)}</span>
                <div class="h-px bg-teal-100 w-full"></div>
              </h2>
              
              {section.projects.map((proj) => (
                <div class="bg-gray-50 rounded-xl p-6 border border-gray-100 shadow-sm mb-8 last:mb-0">
                    <div class="break-inside-avoid flex flex-wrap items-center justify-between gap-2 mb-3">
                      <h3 class="text-[16px] font-bold text-gray-900 flex items-center gap-3">
                      <PortfolioProjectTitleLink
                        href={getPortfolioProjectHref(lang, proj.portfolioSlug, proj.portfolioAnchor)}
                        label={t(proj.title, lang)}
                        className="text-gray-900 hover:text-teal-900 print:text-gray-900 print:no-underline"
                        externalHref={proj.externalUrl}
                        externalVisibility={proj.externalLinkVisibility}
                        externalClassName="text-gray-500 hover:text-teal-900"
                        githubHref={proj.githubUrl}
                        githubClassName="text-gray-500 hover:text-teal-900"
                        googlePlayHref={proj.googlePlayUrl}
                        googlePlayClassName="text-gray-500 hover:text-teal-900"
                        appStoreHref={proj.appStoreUrl}
                        appStoreClassName="text-gray-500 hover:text-teal-900"
                      />
                        {proj.badge && (
                          <span class="bg-indigo-100 text-indigo-700 font-bold px-2 py-0.5 rounded text-[11px] uppercase tracking-wide">
                            {t(proj.badge, lang)}
                          </span>
                        )}
                      </h3>
                      <span class="whitespace-nowrap text-[13px] font-medium text-gray-500">
                        {t(proj.period, lang)}
                      </span>
                    </div>
                    
                    {proj.summary && (
                      <p class="mb-4 whitespace-pre-line text-[14px] text-gray-600 leading-relaxed font-medium">
                        {t(proj.summary, lang)}
                      </p>
                    )}
                    
                    {proj.tech && proj.tech.length > 0 && (
                      <div class="break-inside-avoid flex flex-wrap gap-1.5">
                        {proj.tech.map(tag => (
                           <span class="rounded bg-white border border-gray-200 px-2 py-0.5 text-[12px] font-medium text-gray-700 shadow-sm">{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                ))}
            </>
          ))}

          {/* ACTIVITIES SECTION */}
          {profile.activities && profile.activities.length > 0 && (
            <>
              <h2 class="flex items-center gap-4 mb-8 pt-0 print:break-before-page text-xl font-bold uppercase tracking-wider text-teal-900 shrink-0">
                <span class="shrink-0">{m.activities || 'Activities'}</span>
                <div class="h-px bg-teal-100 w-full"></div>
              </h2>
              {profile.activities.map((a) => (
                <div class="break-inside-avoid border-l-2 border-teal-100 pl-4 py-1 mb-6 last:mb-0">
                  <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
                    <h3 class="text-[15px] font-bold text-gray-900">{t(a.title, lang)}</h3>
                    <span class="whitespace-nowrap text-[11px] font-bold text-teal-700 uppercase tracking-wider">
                      {t(a.period, lang)}
                    </span>
                  </div>
                  {a.description && (
                    <div class="space-y-2">
                      <p class="text-[13px] text-gray-600 leading-relaxed whitespace-pre-line">
                        {t(a.description, lang)}
                      </p>
                      {a.externalUrl && a.externalLabel && (
                        <a
                          href={a.externalUrl}
                          target="_blank"
                          rel="noreferrer"
                          class="inline-flex items-center text-[12px] font-semibold text-teal-700 hover:underline"
                        >
                          [{t(a.externalLabel, lang)}]
                        </a>
                      )}
                    </div>
                  )}
                </div>
              ))}
            </>
          )}
        </section>
      </div>
    </article>
  </body>
</html>

