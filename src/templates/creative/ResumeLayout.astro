---
import type { Lang, ResumeProfile } from '../../lib/resume-types';
import { messages } from '../../lib/messages';
import { t, bullets } from '../../lib/localize';
import { baseUrlJoin } from '../../lib/base-url';
import TemplateSelector from '../../components/TemplateSelector.astro';
import CanvasPrintButton from '../../components/CanvasPrintButton.astro';

interface Props {
  lang: Lang;
  profile: ResumeProfile;
}

const { lang, profile } = Astro.props;
const m = messages(lang);
const other = lang === 'ko' ? 'en' : 'ko';
const otherLangUrl = baseUrlJoin(other, 'creative');
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{m.docTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;900&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <style>
      @page {
        size: A4;
        margin: 15mm;
      }
      @media print {
        body {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }
      }
    </style>
  </head>
  <body class="min-h-screen bg-gray-100 font-sans text-sm leading-relaxed text-gray-800 antialiased" style="font-family: 'Outfit', 'Noto Sans KR', sans-serif;">
    <TemplateSelector lang={lang} currentTemplate="creative" />
    
    <div class="print:hidden mx-auto flex max-w-[1000px] flex-wrap items-center justify-end gap-3 px-8 pb-3 pt-6 text-[13px]">
      <span class="text-gray-500">{m.printHint}</span>
      <CanvasPrintButton />
      <a href={otherLangUrl} class="font-semibold text-teal-600 hover:text-teal-800 hover:underline ml-2">{m.navOther}</a>
    </div>

    <article class="mx-auto max-w-[1000px] bg-white shadow-xl overflow-hidden print:shadow-none print:overflow-visible flex flex-col md:flex-row min-h-screen">
      <!-- Left Sidebar -->
      <aside class="w-full md:w-[320px] shrink-0 bg-teal-900 text-teal-50 p-10 flex flex-col gap-10 print:bg-white print:text-gray-900 print:w-[320px] print:p-0 print:pr-10">
        <div>
          {
            lang === 'en' ? (
              <>
                <h1 class="mb-1 text-4xl font-black tracking-tight text-white leading-tight">
                  {profile.name_en}
                </h1>
                <p class="text-base text-teal-200">{profile.name}</p>
              </>
            ) : (
              <h1 class="mb-2 text-4xl font-black tracking-tight text-white leading-tight">{profile.name}</h1>
            )
          }
        </div>

        <div class="space-y-4 text-[13.5px] text-teal-100">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <span>{profile.contact.phone}</span>
          </div>
          <div class="flex items-center gap-3">
             <svg class="w-5 h-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <a href={`mailto:${profile.contact.email}`} class="hover:text-white transition-colors">{profile.contact.email}</a>
          </div>
          <div class="flex items-center gap-3">
             <svg class="w-5 h-5 text-teal-400" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
            <a href={profile.contact.github_url} target="_blank" rel="noreferrer" class="hover:text-white transition-colors">{profile.contact.github_label}</a>
          </div>
          <div class="flex items-center gap-3">
             <svg class="w-5 h-5 text-teal-400" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" /></svg>
            <a href={profile.contact.linkedin_url} target="_blank" rel="noreferrer" class="hover:text-white transition-colors">{profile.contact.linkedin_label}</a>
          </div>
        </div>

        <div class="space-y-8 mt-4">
          <section>
            <h2 class="mb-4 text-xs font-bold uppercase tracking-widest text-teal-400">
              {m.skills}
            </h2>
            <div class="space-y-4">
              {
                profile.skillGroups.map((g) => (
                  <div class="break-inside-avoid">
                    <div class="mb-1 text-[13px] font-bold text-white">{g.label}</div>
                    <div class="whitespace-pre-line text-[12.5px] leading-relaxed text-teal-100">
                      {lang === 'en' ? g.body_en : g.body_ko}
                    </div>
                  </div>
                ))
              }
            </div>
            {lang === 'en' && profile.languages_note && (
              <div class="mt-4">
                <div class="mb-1 text-[13px] font-bold text-white">{m.languages}</div>
                <div class="whitespace-pre-line text-[12.5px] text-teal-100">
                  {t(profile.languages_note, lang)}
                </div>
              </div>
            )}
          </section>

          <section>
            <h2 class="mb-4 text-xs font-bold uppercase tracking-widest text-teal-400">
              {m.education}
            </h2>
            <div class="space-y-4">
              {
                profile.education.map((ed) => (
                  <div class="break-inside-avoid">
                    <div class="text-[13px] font-bold text-white">{t(ed.school, lang)}</div>
                    <div class="text-[12.5px] text-teal-100">{t(ed.degree, lang)}</div>
                    <div class="text-[11.5px] text-teal-300 mt-0.5">{t(ed.period, lang)}</div>
                  </div>
                ))
              }
            </div>
          </section>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 p-10 md:p-14 md:pl-16 print:p-0">
        <section class="mb-12">
          <p class="whitespace-pre-line text-[16px] text-gray-700 leading-relaxed font-medium">
            {t(profile.summary, lang)}
          </p>
        </section>

        <section class="mb-12 break-inside-avoid">
          <div class="flex items-center gap-4 mb-8">
            <h2 class="text-xl font-bold uppercase tracking-wider text-teal-900 shrink-0">
              {m.experience}
            </h2>
            <div class="h-px bg-teal-100 w-full"></div>
          </div>
          
          <div class="space-y-8">
            {
              profile.experience.map((exp) => (
                <div class="break-inside-avoid relative pl-6 before:absolute before:left-0 before:top-2 before:w-2 before:h-2 before:bg-teal-500 before:rounded-full">
                  <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
                    <h3 class="text-[16px] font-bold text-gray-900">{t(exp.company, lang)}</h3>
                    <span class="whitespace-nowrap text-[13px] font-semibold text-teal-600 bg-teal-50 px-2 py-0.5 rounded-full">
                      {t(exp.period, lang)}
                    </span>
                  </div>
                  {exp.role && (
                    <p class="text-[14px] font-semibold text-gray-700 mb-1.5">{t(exp.role, lang)}</p>
                  )}
                  {lang === 'en' && exp.location_en && (
                    <p class="text-[13px] text-gray-500 mb-3">{exp.location_en}</p>
                  )}
                  <p class="whitespace-pre-line text-[14px] text-gray-600 leading-relaxed">
                    {t(exp.description, lang)}
                  </p>
                </div>
              ))
            }
          </div>
        </section>

        {
          profile.projectSections.map((section) => (
            <section class="mb-12 break-inside-avoid">
              <div class="flex items-center gap-4 mb-8">
                <h2 class="text-xl font-bold uppercase tracking-wider text-teal-900 shrink-0">
                  {t(section.heading, lang)}
                </h2>
                <div class="h-px bg-teal-100 w-full"></div>
              </div>
              
              <div class="grid grid-cols-1 gap-8">
                {section.projects.map((proj) => (
                  <div class="break-inside-avoid bg-gray-50 rounded-xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
                    <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
                      <h3 class="text-[16px] font-bold text-gray-900 flex items-center gap-3">
                        {t(proj.title, lang)}
                        {proj.badge && (
                          <span class="bg-indigo-100 text-indigo-700 font-bold px-2 py-0.5 rounded text-[11px] uppercase tracking-wide">
                            {t(proj.badge, lang)}
                          </span>
                        )}
                      </h3>
                      <span class="whitespace-nowrap text-[13px] font-medium text-gray-500">
                        {t(proj.period, lang)}
                      </span>
                    </div>
                    
                    {proj.summary && (
                      <p class="mb-4 whitespace-pre-line text-[14px] text-gray-600">
                        {t(proj.summary, lang)}
                      </p>
                    )}
                    
                    {proj.tech?.length > 0 && (
                      <div class="mb-4 flex flex-wrap gap-1.5">
                        {proj.tech.map(tag => (
                           <span class="rounded bg-white border border-gray-200 px-2 py-0.5 text-[12px] font-medium text-gray-700 shadow-sm">{tag}</span>
                        ))}
                      </div>
                    )}
                    
                    <ul class="list-disc pl-5 space-y-1.5 marker:text-teal-400">
                      {bullets(proj.highlights, lang).map((line) => (
                        <li class="pl-1 text-[13.5px] text-gray-700">{line}</li>
                      ))}
                    </ul>
                    
                    {proj.results && bullets(proj.results, lang).length > 0 && (
                      <div class="mt-4 pt-4 border-t border-gray-200">
                        <p class="mb-2 text-[13px] font-bold text-teal-800">{m.results}</p>
                        <ul class="list-disc pl-5 space-y-1.5 marker:text-teal-400">
                          {bullets(proj.results, lang).map((line) => (
                            <li class="pl-1 text-[13.5px] text-gray-700">{line}</li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </section>
          ))
        }

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          <section class="print:mb-10">
            <h2 class="mb-5 text-lg font-bold uppercase tracking-wider text-teal-900">
              {m.activities}
            </h2>
            <div class="space-y-4">
              {
                profile.activities.map((a) => (
                  <div class="break-inside-avoid  border-l-2 border-teal-200 pl-3">
                    <div class="text-[14px] font-bold text-gray-900">{t(a.title, lang)}</div>
                    <div class="text-[12.5px] text-gray-500 mt-0.5">{t(a.period, lang)}</div>
                  </div>
                ))
              }
            </div>
          </section>

          {profile.awards.length > 0 && (
            <section>
              <h2 class="mb-5 text-lg font-bold uppercase tracking-wider text-teal-900">
                {m.awards}
              </h2>
              <div class="space-y-4">
                {
                  profile.awards.map((aw) => (
                    <div class="break-inside-avoid  border-l-2 border-teal-200 pl-3">
                      <div class="text-[14px] font-bold text-gray-900">{aw.title}</div>
                      {aw.subtitle && (
                        <div class="text-[13px] text-gray-600 mt-0.5">{t(aw.subtitle, lang)}</div>
                      )}
                    </div>
                  ))
                }
              </div>
            </section>
          )}
        </div>
      </main>
    </article>
  </body>
</html>
