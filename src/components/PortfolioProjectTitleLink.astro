---
interface Props {
  href?: string;
  label: string;
  className?: string;
  externalHref?: string;
  externalVisibility?: 'always' | 'hover';
  externalClassName?: string;
  externalAriaLabel?: string;
  githubHref?: string;
  githubVisibility?: 'always' | 'hover';
  githubClassName?: string;
  googlePlayHref?: string;
  googlePlayVisibility?: 'always' | 'hover';
  googlePlayClassName?: string;
  appStoreHref?: string;
  appStoreVisibility?: 'always' | 'hover';
  appStoreClassName?: string;
}

const {
  href,
  label,
  className = '',
  externalHref,
  externalVisibility = 'always',
  externalClassName = '',
  externalAriaLabel,
  githubHref,
  githubVisibility = 'always',
  githubClassName = '',
  googlePlayHref,
  googlePlayVisibility = 'always',
  googlePlayClassName = '',
  appStoreHref,
  appStoreVisibility = 'always',
  appStoreClassName = '',
} = Astro.props;

const plainClassName = className
  .split(/\s+/)
  .filter(Boolean)
  .filter((token) => !token.startsWith('hover:') && !token.startsWith('focus:'))
  .join(' ');
---

<span class="title-link-group inline-flex items-center gap-1.5">
  {
    href ? (
      <a
        href={href}
        class:list={[
          'transition-colors underline decoration-transparent underline-offset-4 hover:decoration-current',
          'focus:outline-none focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-current/20',
          className,
        ]}
      >
        {label}
      </a>
    ) : (
      <span class:list={[plainClassName]}>{label}</span>
    )
  }
  {externalHref && (
    <a
      href={externalHref}
      target="_blank"
      rel="noreferrer"
      aria-label={externalAriaLabel ?? `${label} external link`}
      data-visibility={externalVisibility}
      class:list={[
        'title-link-icon inline-flex items-center justify-center text-current/60 transition-all duration-150 hover:text-current',
        'focus:outline-none focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-current/20 print:hidden',
        externalClassName,
      ]}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-[0.95em] w-[0.95em]"
        aria-hidden="true"
      >
        <path d="M14 3h7v7" />
        <path d="M10 14 21 3" />
        <path d="M21 14v6a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h6" />
      </svg>
    </a>
  )}
  {githubHref && (
    <a
      href={githubHref}
      target="_blank"
      rel="noreferrer"
      aria-label={`${label} GitHub link`}
      data-visibility={githubVisibility}
      class:list={[
        'title-link-icon inline-flex items-center justify-center text-current/60 transition-all duration-150 hover:text-current',
        'focus:outline-none focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-current/20 print:hidden',
        githubClassName,
      ]}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="h-[1em] w-[1em]"
        aria-hidden="true"
      >
        <path d="M12 .5C5.65.5.5 5.66.5 12.02c0 5.09 3.29 9.4 7.86 10.93.58.11.79-.25.79-.56v-1.96c-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.71.08-.71 1.16.08 1.76 1.2 1.76 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.72-1.55-2.56-.29-5.25-1.29-5.25-5.74 0-1.27.45-2.31 1.19-3.13-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.19 1.2a10.97 10.97 0 0 1 5.8 0c2.22-1.51 3.19-1.2 3.19-1.2.63 1.59.23 2.76.11 3.05.74.82 1.19 1.86 1.19 3.13 0 4.46-2.69 5.44-5.26 5.73.41.35.77 1.04.77 2.1v3.12c0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12.02C23.5 5.66 18.35.5 12 .5Z" />
      </svg>
    </a>
  )}
  {googlePlayHref && (
    <a
      href={googlePlayHref}
      target="_blank"
      rel="noreferrer"
      aria-label={`${label} Google Play link`}
      data-visibility={googlePlayVisibility}
      class:list={[
        'title-link-icon inline-flex items-center justify-center text-current/60 transition-all duration-150 hover:text-current',
        'focus:outline-none focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-current/20 print:hidden',
        googlePlayClassName,
      ]}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="h-[1em] w-[1em]"
        aria-hidden="true"
      >
        <path d="M4.2 2.3a1.2 1.2 0 0 0-.7 1.09v17.22c0 .41.2.8.55 1.03L14.5 12 4.2 2.3Z" />
        <path d="M16.33 10.6 6.06 1.1l12.8 7.22-2.53 2.28Z" opacity=".78" />
        <path d="m16.33 13.4-2.55 2.3L6.05 22.9l12.82-7.24-2.54-2.26Z" opacity=".78" />
        <path d="M20.1 9.1 17.84 11.13 16.8 12l1.04.88 2.28 2.04c.95-.53 1.38-1.07 1.38-1.96 0-.88-.43-1.33-1.4-1.86Z" />
      </svg>
    </a>
  )}
  {appStoreHref && (
    <a
      href={appStoreHref}
      target="_blank"
      rel="noreferrer"
      aria-label={`${label} App Store link`}
      data-visibility={appStoreVisibility}
      class:list={[
        'title-link-icon inline-flex items-center justify-center text-current/60 transition-all duration-150 hover:text-current',
        'focus:outline-none focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-current/20 print:hidden',
        appStoreClassName,
      ]}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="h-[1em] w-[1em]"
        aria-hidden="true"
      >
        <path d="M15.7 2.1c.15 1.03-.25 2.08-.8 2.76-.6.75-1.61 1.33-2.59 1.25-.13-1 .31-2.05.87-2.71.62-.74 1.68-1.27 2.52-1.3Z" />
        <path d="M19.9 17.27c-.48 1.08-.7 1.56-1.32 2.52-.86 1.35-2.08 3.03-3.58 3.04-1.34.01-1.69-.88-3.51-.87-1.82.01-2.2.88-3.54.87-1.5-.01-2.66-1.52-3.52-2.87-2.4-3.7-2.65-8.05-1.17-10.32 1.06-1.62 2.72-2.56 4.28-2.56 1.59 0 2.6.88 3.92.88 1.28 0 2.07-.88 3.9-.88 1.39 0 2.86.76 3.92 2.08-3.43 1.88-2.87 6.8.62 8.11Z" />
      </svg>
    </a>
  )}
</span>

<style>
  @media (hover: hover) and (pointer: fine) {
    .title-link-group .title-link-icon[data-visibility='hover'] {
      opacity: 0;
      pointer-events: none;
      transform: translateY(1px);
    }

    .title-link-group:hover .title-link-icon[data-visibility='hover'],
    .title-link-group:focus-within .title-link-icon[data-visibility='hover'] {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }
  }
</style>
