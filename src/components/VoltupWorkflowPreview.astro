---
import type { Lang } from '@/lib/resume-types';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const isKo = lang === 'ko';

const labels = isKo
  ? {
      eyebrow: 'Example PR Run',
      title: '명령으로 시작되는 Voltup Workflow 실행 예시',
      subtitle:
        'PR 댓글에 명령을 남기면 GitHub Actions bot이 컨텍스트를 읽고, 변경사항 분석·코드 리뷰·PR 본문 갱신 결과를 같은 타임라인에 남깁니다.',
      prStatus: 'Open',
      prTitle: 'feat(admin): 파트너 정산 관리 API 정리 및 배포 준비',
      prMeta: 'sprint/feature -> deploy/prod · 64 commits · 27 files changed',
      developer: 'developer',
      actionUser: 'github-actions',
      bot: 'Bot',
      commentLabel: 'commented',
      commandReview: '/voltup-review -t security',
      commandPr: '/voltup-pr',
      acceptedTitle: 'Workflow accepted',
      acceptedRows: [
        ['Command', '/voltup-review -t security'],
        ['Context', 'project-context, review-template, docs'],
        ['Diff scope', '27 files · 3 review clusters'],
      ],
      detectorTitle: 'PR 변경사항 분석 결과',
      detectorMeta: 'pr-changes-detector · comment upsert',
      changeGroups: [
        {
          title: 'Flyway 마이그레이션 (4개)',
          status: 'OK',
          items: [
            ['V28__settlement_category_index.sql', 'settlement_config 테이블 category 인덱스 추가'],
            ['V29__partner_ticket_id.sql', 'support_ticket 테이블에 partner_ticket_id 컬럼 추가'],
            ['V30__notice_pin_flag.sql', 'admin_notice 상단 고정 플래그 및 복합 인덱스 추가'],
          ],
        },
        {
          title: 'Admin API 컨트롤러 (16개)',
          status: 'review',
          items: [
            ['SettlementCommandController.kt', '[POST] /admin/settlements/{settlementId}/retry 제거'],
            ['StoreAdminController.kt', '매장 정산 QR 조회 응답에 채널별 매핑 정보 보강'],
            ['CustomerNoticeController.kt', '고객 공지 템플릿 조회 API 제거 후 알림 브리지로 이전'],
          ],
        },
      ],
      reviewTitle: 'AI 코드 리뷰 결과',
      reviewMeta: '/voltup-review · review posted',
      severity: ['Critical 0', 'High 0', 'Medium 6', 'Low 1'],
      reviewSummary: [
        '정산 재시도 endpoint 제거 범위와 caller 영향도를 같은 클러스터에서 검토',
        '매장 QR 응답 보강 로직의 null/empty 케이스를 리뷰 포인트로 표시',
        '운영 영향이 낮은 단순 삭제는 Low priority로 분리',
      ],
      inlineFile: 'StoreAdminController.kt',
      inlineComment:
        '채널별 QR 코드가 누락될 경우 관리자 화면 응답의 정산 상태와 매장 매핑 정보가 어긋날 수 있어 fallback 응답을 명시하는 편이 안전합니다.',
      securityTitle: 'Security agent loop',
      securitySteps: ['Find', 'Context expand', 'Refute'],
      prDocTitle: 'PR 본문 자동 생성',
      prDocMeta: '/voltup-pr · marker block update',
      prDocSections: [
        ['Summary', '파트너 정산 관리 API 정리와 배포 브랜치 병합 준비'],
        ['Changes', '정산 마이그레이션, Admin API 삭제/보강, 매장 QR 조회 응답 정리'],
        ['Validation', '배포 전 Flyway 적용 순서와 정산 재시도 호출 경로 확인'],
      ],
      doneTitle: 'PR timeline updated',
      doneBody: '기존 수기 본문은 보존하고, voltup-pr marker block만 교체했습니다.',
    }
  : {
      eyebrow: 'Example PR Run',
      title: 'Voltup Workflow starts from PR comments',
      subtitle:
        'A developer leaves a command on a PR, then the GitHub Actions bot writes change analysis, code review, and PR-body updates back into the same timeline.',
      prStatus: 'Open',
      prTitle: 'feat(admin): clean up partner settlement APIs and prepare release',
      prMeta: 'sprint/feature -> deploy/prod · 64 commits · 27 files changed',
      developer: 'developer',
      actionUser: 'github-actions',
      bot: 'Bot',
      commentLabel: 'commented',
      commandReview: '/voltup-review -t security',
      commandPr: '/voltup-pr',
      acceptedTitle: 'Workflow accepted',
      acceptedRows: [
        ['Command', '/voltup-review -t security'],
        ['Context', 'project-context, review-template, docs'],
        ['Diff scope', '27 files · 3 review clusters'],
      ],
      detectorTitle: 'PR Change Analysis',
      detectorMeta: 'pr-changes-detector · comment upsert',
      changeGroups: [
        {
          title: 'Flyway migrations (4)',
          status: 'OK',
          items: [
            ['V28__settlement_category_index.sql', 'Add category index to settlement_config'],
            ['V29__partner_ticket_id.sql', 'Add partner_ticket_id to support_ticket'],
            ['V30__notice_pin_flag.sql', 'Add pinned flag and composite index to admin_notice'],
          ],
        },
        {
          title: 'Admin API controllers (16)',
          status: 'review',
          items: [
            ['SettlementCommandController.kt', 'Remove [POST] /admin/settlements/{settlementId}/retry'],
            ['StoreAdminController.kt', 'Add channel-level QR mapping to store settlement responses'],
            ['CustomerNoticeController.kt', 'Move notice-template lookup behind a notification bridge'],
          ],
        },
      ],
      reviewTitle: 'AI Code Review Result',
      reviewMeta: '/voltup-review · review posted',
      severity: ['Critical 0', 'High 0', 'Medium 6', 'Low 1'],
      reviewSummary: [
        'Reviews settlement retry endpoint removal and caller impact in one cluster',
        'Flags null/empty cases in the store QR response enrichment path',
        'Separates low-risk deletions into Low priority comments',
      ],
      inlineFile: 'StoreAdminController.kt',
      inlineComment:
        'If channel-level QR codes are missing, the admin response can drift from settlement status and store mapping data. Add an explicit fallback response.',
      securityTitle: 'Security agent loop',
      securitySteps: ['Find', 'Context expand', 'Refute'],
      prDocTitle: 'PR Body Generated',
      prDocMeta: '/voltup-pr · marker block update',
      prDocSections: [
        ['Summary', 'Clean up partner settlement APIs and prepare release merge'],
        ['Changes', 'Settlement migrations, Admin API removals/refinements, store QR response updates'],
        ['Validation', 'Check Flyway order and settlement retry caller paths before deployment'],
      ],
      doneTitle: 'PR timeline updated',
      doneBody: 'Manual PR notes are preserved; only the voltup-pr marker block is replaced.',
    };
---

<section class="rounded-[1.35rem] border border-slate-900/10 bg-[linear-gradient(180deg,#f9fbfd_0%,#eef7f3_100%)] p-4 sm:p-5">
  <div class="max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-800">
      {labels.eyebrow}
    </p>
    <h3 class="mt-2 text-xl font-semibold tracking-[-0.02em] text-slate-950">
      {labels.title}
    </h3>
    <p class="mt-2 text-sm leading-7 text-slate-600">
      {labels.subtitle}
    </p>
  </div>

  <div class="mt-5 overflow-hidden rounded-[1.15rem] border border-slate-900/10 bg-[#0f1720] shadow-[0_24px_70px_-48px_rgba(15,23,42,0.65)]">
    <header class="border-b border-white/10 bg-[#111923] px-4 py-4">
      <div class="flex flex-wrap items-center gap-3">
        <span class="rounded-full bg-emerald-500 px-3 py-1 text-sm font-bold text-white">
          {labels.prStatus}
        </span>
        <h4 class="min-w-0 break-words text-base font-semibold text-slate-50 sm:text-lg">
          {labels.prTitle}
        </h4>
      </div>
      <p class="mt-2 text-xs leading-5 text-slate-400 [overflow-wrap:anywhere]">
        {labels.prMeta}
      </p>
    </header>

    <div class="space-y-4 p-3 sm:p-4">
      <article class="grid min-w-0 grid-cols-[2rem_minmax(0,1fr)] gap-3 sm:grid-cols-[2.5rem_minmax(0,1fr)]">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-sky-100 text-xs font-bold text-sky-900 sm:h-10 sm:w-10">
          DV
        </div>
        <section class="min-w-0 rounded-[1rem] border border-white/10 bg-[#151f2a]">
          <div class="border-b border-white/10 px-4 py-3">
            <p class="text-sm font-semibold text-slate-100">
              {labels.developer}
              <span class="ml-1 text-xs font-normal text-slate-500">{labels.commentLabel}</span>
            </p>
          </div>
          <div class="p-4">
            <code class="block rounded-xl border border-sky-200/10 bg-black/24 px-3 py-3 text-sm font-semibold text-sky-100 [overflow-wrap:anywhere]">
              {labels.commandReview}
            </code>
          </div>
        </section>
      </article>

      <article class="grid min-w-0 grid-cols-[2rem_minmax(0,1fr)] gap-3 sm:grid-cols-[2.5rem_minmax(0,1fr)]">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-50 text-xs font-black text-slate-950 sm:h-10 sm:w-10">
          GH
        </div>
        <section class="min-w-0 rounded-[1rem] border border-white/10 bg-[#151f2a]">
          <div class="border-b border-white/10 px-4 py-3">
            <p class="text-sm font-semibold text-slate-100">
              {labels.actionUser}
              <span class="ml-1 rounded-full border border-white/15 px-1.5 py-0.5 text-[10px] text-slate-400">{labels.bot}</span>
            </p>
          </div>
          <div class="p-4">
            <h5 class="text-base font-semibold text-white">{labels.acceptedTitle}</h5>
            <div class="mt-3 grid gap-2">
              {labels.acceptedRows.map(([name, value]) => (
                <div class="grid gap-1 rounded-xl border border-white/10 bg-white/[0.04] px-3 py-3 sm:grid-cols-[7rem_minmax(0,1fr)]">
                  <span class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">{name}</span>
                  <span class="text-xs font-medium text-slate-200 [overflow-wrap:anywhere]">{value}</span>
                </div>
              ))}
            </div>
          </div>
        </section>
      </article>

      <article class="grid min-w-0 grid-cols-[2rem_minmax(0,1fr)] gap-3 sm:grid-cols-[2.5rem_minmax(0,1fr)]">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-50 text-xs font-black text-slate-950 sm:h-10 sm:w-10">
          GH
        </div>
        <section class="min-w-0 rounded-[1rem] border border-white/10 bg-[#151f2a]">
          <div class="border-b border-white/10 px-4 py-3">
            <p class="text-sm font-semibold text-slate-100">
              {labels.actionUser}
              <span class="ml-1 rounded-full border border-white/15 px-1.5 py-0.5 text-[10px] text-slate-400">{labels.bot}</span>
            </p>
            <p class="mt-1 text-xs text-slate-500">{labels.detectorMeta}</p>
          </div>
          <div class="p-4">
            <h5 class="text-lg font-semibold text-white">{labels.detectorTitle}</h5>
            <div class="mt-4 grid gap-3">
              {labels.changeGroups.map((group) => (
                <section class="min-w-0 rounded-xl border border-white/10 bg-white/[0.04] p-4">
                  <div class="flex flex-wrap items-center justify-between gap-2">
                    <p class="text-sm font-semibold text-slate-100">{group.title}</p>
                    <span class:list={[
                      'rounded-md px-2 py-1 text-xs font-semibold',
                      group.status === 'OK'
                        ? 'bg-emerald-400/15 text-emerald-100'
                        : 'bg-amber-300/15 text-amber-100',
                    ]}>
                      {group.status}
                    </span>
                  </div>
                  <ul class="mt-3 space-y-3">
                    {group.items.map(([file, summary]) => (
                      <li class="text-xs leading-5 text-slate-300 [overflow-wrap:anywhere]">
                        <span class="font-semibold text-sky-300 [overflow-wrap:anywhere]">{file}</span>
                        <span class="mx-1 text-slate-500">-</span>
                        <span>{summary}</span>
                      </li>
                    ))}
                  </ul>
                </section>
              ))}
            </div>
          </div>
        </section>
      </article>

      <article class="grid min-w-0 grid-cols-[2rem_minmax(0,1fr)] gap-3 sm:grid-cols-[2.5rem_minmax(0,1fr)]">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-50 text-xs font-black text-slate-950 sm:h-10 sm:w-10">
          GH
        </div>
        <section class="min-w-0 rounded-[1rem] border border-emerald-200/15 bg-[#121d27]">
          <div class="border-b border-white/10 px-4 py-3">
            <p class="text-sm font-semibold text-slate-100">
              {labels.actionUser}
              <span class="ml-1 rounded-full border border-white/15 px-1.5 py-0.5 text-[10px] text-slate-400">{labels.bot}</span>
            </p>
            <p class="mt-1 text-xs text-emerald-300">{labels.reviewMeta}</p>
          </div>
          <div class="p-4">
            <h5 class="text-lg font-semibold text-white">{labels.reviewTitle}</h5>
            <div class="mt-3 grid gap-2 sm:grid-cols-2">
              {labels.severity.map((item) => (
                <div class="rounded-lg border border-white/10 bg-white/[0.06] px-3 py-2 text-xs font-semibold text-slate-100">
                  {item}
                </div>
              ))}
            </div>
            <ul class="mt-4 space-y-2">
              {labels.reviewSummary.map((item) => (
                <li class="flex gap-2 text-xs leading-5 text-slate-300">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-300"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <div class="mt-4 rounded-xl border border-white/10 bg-black/20 p-3">
              <p class="text-[11px] font-semibold text-sky-300 [overflow-wrap:anywhere]">{labels.inlineFile}</p>
              <p class="mt-2 text-xs leading-6 text-slate-200 [overflow-wrap:anywhere]">{labels.inlineComment}</p>
            </div>
            <div class="mt-4 rounded-xl border border-emerald-200/10 bg-emerald-300/[0.08] p-3">
              <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-emerald-200">{labels.securityTitle}</p>
              <div class="mt-2 flex flex-wrap gap-2">
                {labels.securitySteps.map((item) => (
                  <span class="rounded-full bg-black/20 px-3 py-1 text-[11px] font-semibold text-emerald-50">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </section>
      </article>

      <article class="grid min-w-0 grid-cols-[2rem_minmax(0,1fr)] gap-3 sm:grid-cols-[2.5rem_minmax(0,1fr)]">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-sky-100 text-xs font-bold text-sky-900 sm:h-10 sm:w-10">
          DV
        </div>
        <section class="min-w-0 rounded-[1rem] border border-white/10 bg-[#151f2a]">
          <div class="border-b border-white/10 px-4 py-3">
            <p class="text-sm font-semibold text-slate-100">
              {labels.developer}
              <span class="ml-1 text-xs font-normal text-slate-500">{labels.commentLabel}</span>
            </p>
          </div>
          <div class="p-4">
            <code class="block rounded-xl border border-sky-200/10 bg-black/24 px-3 py-3 text-sm font-semibold text-sky-100 [overflow-wrap:anywhere]">
              {labels.commandPr}
            </code>
          </div>
        </section>
      </article>

      <article class="grid min-w-0 grid-cols-[2rem_minmax(0,1fr)] gap-3 sm:grid-cols-[2.5rem_minmax(0,1fr)]">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-50 text-xs font-black text-slate-950 sm:h-10 sm:w-10">
          GH
        </div>
        <section class="min-w-0 rounded-[1rem] border border-white/10 bg-white text-slate-900">
          <div class="border-b border-slate-900/10 px-4 py-3">
            <p class="text-sm font-semibold text-slate-900">
              {labels.actionUser}
              <span class="ml-1 rounded-full border border-slate-900/15 px-1.5 py-0.5 text-[10px] text-slate-500">{labels.bot}</span>
            </p>
            <p class="mt-1 text-xs text-slate-500">{labels.prDocMeta}</p>
          </div>
          <div class="p-4">
            <h5 class="text-lg font-semibold text-slate-950">{labels.prDocTitle}</h5>
            <div class="mt-4 rounded-xl border border-slate-900/10 bg-slate-50 p-3">
              <p class="text-[11px] font-semibold text-slate-400">&lt;!-- voltup-pr:begin --&gt;</p>
              <div class="mt-3 space-y-3">
                {labels.prDocSections.map(([title, body]) => (
                  <section class="min-w-0 rounded-lg border border-slate-900/10 bg-white px-3 py-3">
                    <p class="text-xs font-semibold text-slate-950">{title}</p>
                    <p class="mt-1 text-xs leading-5 text-slate-600">{body}</p>
                  </section>
                ))}
              </div>
              <p class="mt-3 text-[11px] font-semibold text-slate-400">&lt;!-- voltup-pr:end --&gt;</p>
            </div>
            <p class="mt-3 text-xs leading-5 text-slate-500">{labels.doneBody}</p>
          </div>
        </section>
      </article>
    </div>
  </div>
</section>
